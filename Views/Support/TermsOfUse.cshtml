@{ ViewData["Title"] = "Terms of Use"; }

@section Styles {
<style>
html {
    scroll-behavior: smooth;
}
</style>
}

<div class="flex-grow p-gutter relative overflow-hidden w-full flex flex-col items-center">
    <!-- Header Section -->
    <div class="mb-lg text-center max-w-4xl w-full">
        <h1 class="font-h1 text-h1 text-primary mb-xs"><span class="lang-en">Terms of Use</span><span class="lang-tr">Kullanım Şartları</span></h1>
