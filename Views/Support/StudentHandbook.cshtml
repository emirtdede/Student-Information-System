@{ ViewData["Title"] = "Student Handbook"; }

@section Styles {
<style>
.material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
        }
        .fill-icon {
            font-variation-settings: 'FILL' 1;
        }
</style>
}

<div class="flex-grow p-gutter relative overflow-hidden w-full flex flex-col items-center">
<!-- Content Area -->
<article class="w-full max-w-4xl mx-auto glass-card rounded-xl p-lg bg-surface-container-lowest">
<!-- Welcome Section -->
<section class="mb-xl" id="welcome">
<h1 class="font-h1 text-h1 text-on-background mb-md text-center"><span class="lang-en">Student Handbook</span><span class="lang-tr">Öğrenci El Kitabı</span></h1>
<p class="font-body-lg text-body-lg text-on-surface-variant mb-6 text-center"><span class="lang-en">Welcome to Osmaniye Korkut Ata University. This handbook is designed to provide you with essential information regarding your academic journey, campus resources, and student responsibilities.</span><span class="lang-tr">Osmaniye Korkut Ata Üniversitesi'ne hoş geldiniz. Bu el kitabı, akademik yolculuğunuz, kampüs kaynakları ve öğrenci sorumlulukları hakkında temel bilgiler sağlamak için tasarlanmıştır.</span></p>
<div class="h-64 rounded-lg overflow-hidden mb-8 bg-surface-container relative">
<img alt="University Campus" class="w-full h-full object-cover" data-alt="A wide, cinematic shot of a modern university campus during golden hour. The sunlight gently illuminates the contemporary glass and concrete architecture of the main library building. Students are casually walking along a wide, tree-lined path in the foreground. The mood is academic, inspiring, and peaceful, perfectly capturing the essence of higher education in a clean, professional aesthetic." src="https://lh3.googleusercontent.com/aida-public/AB6AXuDKsJH0GPM-oFn-EOQnV2Tt0GLRe3RUgh3l7lvrJnTOug0Njw-dYGHbIkMKCqQbPoYmjY_Gpq1JUdhbuM_KQsS6o7UomXiSILQ84r7m5eaAC8uxA-bCh57iSdn2-xd5GqYjKMWlVf6O-Oz02rLNfCeMeppTBx-t0siIFzfcxaO3BNz91OWlyRcE6o4ICZJHJzyKbgcGgEKw2T6-rlmA4RdeyFhUwYkRaasJG9HS7KsZukhXZrYm0So13NcimN7ItzIUSR2ENFtQ4yqk"/>
<div class="absolute inset-0 bg-gradient-to-t from-black/50 to-transparent flex items-end p-md">
<span class="text-white font-label-md flex items-center gap-2"><span class="material-symbols-outlined text-sm">location_on</span> <span class="lang-en">OKÜ Main Campus</span><span class="lang-tr">OKÜ Merkez Kampüs</span></span>
</div>
</div>
</section>
<!-- Academic Regulations Section -->
<section class="mb-xl border-t border-outline-variant/30 pt-xl" id="academic-regulations">
<h2 class="font-h2 text-h2 text-secondary mb-md flex items-center gap-2">
<span class="material-symbols-outlined text-secondary fill-icon" data-icon="menu_book">menu_book</span>
                    <span class="lang-en">Academic Regulations</span><span class="lang-tr">Akademik Yönetmelikler</span>
                </h2>
<div class="grid grid-cols-1 md:grid-cols-2 gap-md">
<div class="p-md rounded-lg bg-surface-container-low hover:bg-surface-container transition-colors">
<h4 class="font-h3 text-h3 text-on-surface mb-2"><span class="lang-en">Grading System</span><span class="lang-tr">Not Sistemi</span></h4>
<p class="text-on-surface-variant text-sm"><span class="lang-en">Understand the credit system, letter grades (AA, BA, BB, etc.), and GPA calculation methodologies.</span><span class="lang-tr">Kredi sistemi, harf notları (AA, BA, BB, vb.) ve GNO hesaplama yöntemlerini anlayın.</span></p>
</div>
<div class="p-md rounded-lg bg-surface-container-low hover:bg-surface-container transition-colors">
<h4 class="font-h3 text-h3 text-on-surface mb-2"><span class="lang-en">Attendance Policy</span><span class="lang-tr">Devam Politikası</span></h4>
<p class="text-on-surface-variant text-sm"><span class="lang-en">Details on mandatory attendance requirements for theoretical and practical courses.</span><span class="lang-tr">Teorik ve uygulamalı dersler için zorunlu devam koşulları hakkında detaylar.</span></p>
</div>
</div>
</section>
<!-- IT Support Section -->
<section class="mb-xl border-t border-outline-variant/30 pt-xl" id="it-support">
<h2 class="font-h2 text-h2 text-primary mb-md flex items-center gap-2">
<span class="material-symbols-outlined text-primary fill-icon" data-icon="computer">computer</span>
                    <span class="lang-en">IT Support</span><span class="lang-tr">BT Destek</span>
                </h2>
<p class="text-on-surface-variant mb-6"><span class="lang-en">Need help with your OBS account, Eduroam Wi-Fi, or university email? Our IT department is here to assist.</span><span class="lang-tr">OBS hesabınız, Eduroam Wi-Fi veya üniversite e-postanız hakkında yardıma mı ihtiyacınız var? Bilgi İşlem dairemiz yardımcı olmak için burada.</span></p>
<div class="bg-surface-container p-md rounded-lg flex items-center justify-between border border-primary/20">
<div>
<span class="font-label-md text-primary block mb-1"><span class="lang-en">Help Desk</span><span class="lang-tr">Yardım Masası</span></span>
<span class="text-on-surface font-body-md block">bilgiislem@@osmaniye.edu.tr</span>
</div>
<button onclick="window.location.href='mailto:bilgiislem@@osmaniye.edu.tr'" class="px-md py-2 bg-primary text-on-primary rounded-lg font-label-md hover:bg-primary/90 transition-colors shadow-sm flex items-center gap-2">
<span class="material-symbols-outlined text-sm">mail</span>
                        <span class="lang-en">Contact Support</span><span class="lang-tr">Destekle İletişime Geç</span>
                    </button>
</div>
</section>
</article>
</div>

@section Scripts {
<script>
</script>
}
