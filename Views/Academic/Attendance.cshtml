@model List<Student_Information_System.Models.Enrollment>
@{ ViewData["Title"] = "Devamsızlık Takibi"; }

@section Styles {
<style>
.progress-bar-fill {
    transition: width 1s cubic-bezier(0.4, 0, 0.2, 1);
}
</style>
}

<div class="flex-grow p-gutter relative overflow-hidden w-full">
<div class="p-gutter md:p-lg max-w-container-max mx-auto w-full flex-1">
<!-- Page Header -->
<div class="mb-lg">
<h1 class="font-h1-mobile md:font-h1 text-h1-mobile md:text-h1 font-bold text-on-background mb-xs"><span class="lang-en">Attendance Tracking</span><span class="lang-tr">Devamsızlık Takibi</span></h1>
<p class="font-body-lg text-body-lg text-on-surface-variant"><span class="lang-en">You can track the attendance status of your registered courses here.</span><span class="lang-tr">Kayıtlı olduğunuz derslerin devamsızlık durumlarını buradan takip edebilirsiniz.</span></p>
</div>
<!-- Grid Layout for Attendance Cards -->
<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-gutter">
    @if(Model != null && Model.Count > 0)
    {
        foreach (var enrollment in Model)
        {
            var totalClasses = 14; // Fixed 14 weeks limit
            var absentCount = enrollment.AbsentCount; // From Database
            var attendancePercent = (int)(((totalClasses - absentCount) / (double)totalClasses) * 100);
            if (attendancePercent < 0) attendancePercent = 0;
            var isWarning = absentCount > 2; // Warning if 3 or 4
            var isFailed = absentCount > 4; // FZ
            
            <div class="glass-card rounded-xl p-md flex flex-col relative overflow-hidden group hover:bg-white/80 dark:hover:bg-[#1a1a1a]/80 transition-all duration-300 @(isFailed ? "ring-2 ring-error" : (isWarning ? "ring-2 ring-error-container/50" : ""))">
                @if(isWarning) {
                    <div class="absolute top-0 right-0 w-32 h-32 bg-error-container/20 rounded-full blur-3xl -mr-16 -mt-16 group-hover:bg-error-container/30 transition-colors"></div>
                } else {
                    <div class="absolute top-0 right-0 w-32 h-32 bg-secondary-container/20 rounded-full blur-3xl -mr-16 -mt-16 group-hover:bg-secondary-container/30 transition-colors"></div>
                }
                
                <div class="flex justify-between items-start mb-sm relative z-10">
                    <div>
                        @if(isFailed) {
                            <span class="inline-block px-sm py-xs rounded-full bg-error text-on-error font-label-sm text-label-sm mb-sm flex items-center gap-xs shadow-sm">
                                <span class="material-symbols-outlined text-[14px]">cancel</span> <span class="lang-en">Failed due to Absences (FZ)</span><span class="lang-tr">Devamsızlıktan Kaldı (FZ)</span>
                            </span>
                        } else if(isWarning) {
                            <span class="inline-block px-sm py-xs rounded-full bg-error-container text-on-error-container font-label-sm text-label-sm mb-sm flex items-center gap-xs">
                                <span class="material-symbols-outlined text-[14px]">warning</span> <span class="lang-en">Warning Limit</span><span class="lang-tr">Uyarı Sınırı</span>
                            </span>
                        } else {
                            <span class="inline-block px-sm py-xs rounded-full bg-secondary-container text-on-secondary-container font-label-sm text-label-sm mb-sm flex items-center gap-xs">
                                <span class="material-symbols-outlined text-[14px]">check_circle</span> <span class="lang-en">Normal</span><span class="lang-tr">Normal</span>
                            </span>
                        }
                        <h3 class="font-h3 text-h3 text-on-background line-clamp-2">@enrollment.Course.Name</h3>
                    </div>
                    <span class="material-symbols-outlined text-outline-variant">class</span>
                </div>
                <div class="mt-auto relative z-10">
                    <div class="flex justify-between items-end mb-xs">
                        <div class="flex flex-col">
                            <span class="font-label-sm text-label-sm text-on-surface-variant"><span class="lang-en">Attendance Rate</span><span class="lang-tr">Devam Oranı</span></span>
                            <span class="font-h2 text-h2 @(isFailed ? "text-error" : (isWarning ? "text-error" : "text-primary")) font-bold">@attendancePercent<span class="text-body-md font-normal text-outline">%</span></span>
                        </div>
                        <div class="text-right">
                            <p class="font-label-sm text-label-sm @(isFailed ? "text-error" : (isWarning ? "text-error" : "text-on-surface-variant"))"><span class="lang-en">@absentCount Weeks Absent / @totalClasses Total</span><span class="lang-tr">@absentCount Hafta Devamsız / @totalClasses Toplam</span></p>
                        </div>
                    </div>
                    <!-- Progress Bar -->
                    <div class="h-2 w-full bg-surface-container-high rounded-full overflow-hidden">
                        <div class="h-full @(isFailed ? "bg-error" : (isWarning ? "bg-error-container" : "bg-primary")) progress-bar-fill" style="width: @attendancePercent%;"></div>
                    </div>
                    @if(isFailed){ <p class="font-label-sm text-label-sm text-error mt-xs font-bold"><span class="lang-en">You exceeded the maximum absence limit (4 Weeks).</span><span class="lang-tr">Maksimum devamsızlık sınırını (4 Hafta) aştınız.</span></p> }
                    else if(isWarning){ <p class="font-label-sm text-label-sm text-error mt-xs"><span class="lang-en">You are approaching the absence limit!</span><span class="lang-tr">Devamsızlık sınırına yaklaşıyorsunuz!</span></p> }
                </div>
            </div>
        }
    }
    else
    {
        <div class="col-span-full p-lg text-center font-body-lg text-on-surface-variant">
            <span class="lang-en">Attendance data cannot be displayed because you have no active course registrations.</span><span class="lang-tr">Aktif ders kaydınız bulunmadığı için devamsızlık verisi gösterilemiyor.</span>
        </div>
    }
</div>

</div>
</div>
