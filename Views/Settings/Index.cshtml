@model Student_Information_System.Models.Student
@{ ViewData["Title"] = "Settings"; }

@section Styles {
<style>
@@layer utilities {
            .material-symbols-outlined {
                font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
            }
        }
</style>
}

<div class="flex-grow p-gutter relative overflow-hidden w-full">
<div class="mb-lg">
<h1 class="font-h1 text-h1 text-on-surface mb-xs"><span class="lang-en">Settings</span><span class="lang-tr">Ayarlar</span></h1>
<p class="font-body-md text-body-md text-on-surface-variant"><span class="lang-en">Manage your account preferences and personal information.</span><span class="lang-tr">Hesap tercihlerinizi ve kişisel bilgilerinizi yönetin.</span></p>
</div>
<!-- Bento Layout for Settings -->
<div class="grid grid-cols-1 lg:grid-cols-12 gap-md">
<!-- Settings Navigation (Left Col) -->
<nav class="lg:col-span-3 space-y-xs">
<div class="glass-panel rounded-xl p-xs flex flex-col gap-xs">
<button class="tab-btn w-full flex items-center gap-sm px-sm py-sm rounded-lg text-left transition-colors bg-primary/10 text-primary font-label-md text-label-md" data-target="profile" onclick="switchTab('profile')">
<span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1;">person</span>
                            <span class="lang-en">Profile</span><span class="lang-tr">Profil</span>
                        </button>
<button class="tab-btn w-full flex items-center gap-sm px-sm py-sm rounded-lg text-left transition-colors text-on-surface-variant hover:bg-surface-container/50 font-label-md text-label-md" data-target="preferences" onclick="switchTab('preferences')">
<span class="material-symbols-outlined">tune</span>
                            <span class="lang-en">Preferences</span><span class="lang-tr">Tercihler</span>
                        </button>
<button class="tab-btn w-full flex items-center gap-sm px-sm py-sm rounded-lg text-left transition-colors text-on-surface-variant hover:bg-surface-container/50 font-label-md text-label-md" data-target="security" onclick="switchTab('security')">
<span class="material-symbols-outlined">lock</span>
                            <span class="lang-en">Security</span><span class="lang-tr">Güvenlik</span>
                        </button>
</div>
</nav>
<!-- Settings Content (Right Col) -->
<div class="lg:col-span-9 relative">
<!-- Profile Section -->
<section class="tab-content block animate-fade-in" id="section-profile">
<div class="glass-panel rounded-xl p-md">
<h2 class="font-h3 text-h3 text-on-surface mb-md pb-xs border-b border-outline-variant/30"><span class="lang-en">Personal Information</span><span class="lang-tr">Kişisel Bilgiler</span></h2>
<div class="flex flex-col md:flex-row gap-lg items-start">
<div class="flex flex-col items-center gap-sm">
<div class="w-32 h-32 rounded-full overflow-hidden border-4 border-surface shadow-sm relative group cursor-pointer" onclick="triggerPhotoUpload()">
                        <img id="profile-preview-img" alt="Profile" class="w-full h-full object-contain bg-white" src="/profile.png"/>
                        <div class="absolute inset-0 bg-black/40 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity">
                            <span class="material-symbols-outlined text-white">photo_camera</span>
                        </div>
                    </div>
                    <button class="font-label-sm text-label-sm text-primary hover:underline" onclick="triggerPhotoUpload()"><span class="lang-en">Change Photo</span><span class="lang-tr">Fotoğrafı Değiştir</span></button>
                    <input type="file" id="profile-file-input" class="hidden" accept="image/*" onchange="previewProfilePhoto(event)" />
                </div>
                <div class="flex-1 w-full space-y-md">
                    <form id="form-personal-info" onsubmit="savePersonalInfo(event)">
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-sm mb-md">
                            <div>
                                <label class="block font-label-sm text-label-sm text-on-surface-variant mb-xs"><span class="lang-en">First Name</span><span class="lang-tr">Ad</span></label>
                                <input id="profile-first-name" class="w-full bg-surface-container-low border border-outline-variant/50 rounded-lg px-sm py-sm font-body-md text-body-md text-on-surface focus:ring-2 focus:ring-primary focus:border-primary transition-shadow" type="text" value="@Model.FirstName"/>
                            </div>
                            <div>
                                <label class="block font-label-sm text-label-sm text-on-surface-variant mb-xs"><span class="lang-en">Last Name</span><span class="lang-tr">Soyad</span></label>
                                <input id="profile-last-name" class="w-full bg-surface-container-low border border-outline-variant/50 rounded-lg px-sm py-sm font-body-md text-body-md text-on-surface focus:ring-2 focus:ring-primary focus:border-primary transition-shadow" type="text" value="@Model.LastName"/>
                            </div>
                        </div>
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-sm mb-md">
                            <div>
                                <label class="block font-label-sm text-label-sm text-on-surface-variant mb-xs"><span class="lang-en">Student ID</span><span class="lang-tr">Öğrenci Numarası</span></label>
                                <input class="w-full bg-surface-container border border-outline-variant/30 rounded-lg px-sm py-sm font-body-md text-body-md text-on-surface-variant cursor-not-allowed opacity-70" disabled="" type="text" value="@Model.StudentNumber"/>
                            </div>
                            <div>
                                <label class="block font-label-sm text-label-sm text-on-surface-variant mb-xs"><span class="lang-en">Email Address</span><span class="lang-tr">E-posta Adresi</span></label>
                                <input id="profile-email" class="w-full bg-surface-container-low border border-outline-variant/50 rounded-lg px-sm py-sm font-body-md text-body-md text-on-surface focus:ring-2 focus:ring-primary focus:border-primary transition-shadow" type="email" value="@Model.Email"/>
                            </div>
                        </div>
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-sm mb-md">
                            <div>
                                <label class="block font-label-sm text-label-sm text-on-surface-variant mb-xs"><span class="lang-en">Phone Number</span><span class="lang-tr">Telefon Numarası</span></label>
                                <input id="profile-phone" class="w-full bg-surface-container-low border border-outline-variant/50 rounded-lg px-sm py-sm font-body-md text-body-md text-on-surface focus:ring-2 focus:ring-primary focus:border-primary transition-shadow" type="tel" value="+90 555 123 4567"/>
                            </div>
                        </div>
                        <div class="pt-sm flex justify-end">
                            <button type="submit" class="bg-primary text-on-primary font-label-md text-label-md px-md py-sm rounded-lg hover:bg-primary/90 transition-colors shadow-sm active:scale-95">
                                <span class="lang-en">Save Changes</span><span class="lang-tr">Değişiklikleri Kaydet</span>
                            </button>
                        </div>
                    </form>
                </div>
</div>
</div>
</section>
<!-- Preferences Section -->
<section class="tab-content hidden animate-fade-in" id="section-preferences">
<div class="glass-panel rounded-xl p-md space-y-lg">
<div>
<h2 class="font-h3 text-h3 text-on-surface mb-xs"><span class="lang-en">Appearance</span><span class="lang-tr">Görünüm</span></h2>
<p class="font-body-md text-body-md text-on-surface-variant mb-md"><span class="lang-en">Customize how OKÜ-OBS looks on your device.</span><span class="lang-tr">OKÜ-OBS'nin cihazınızda nasıl görüneceğini özelleştirin.</span></p>
<div class="flex items-center justify-between p-sm border border-outline-variant/30 rounded-lg bg-surface-container-lowest">
<div class="flex items-center gap-sm">
<div class="w-10 h-10 rounded-full bg-surface-container flex items-center justify-center text-on-surface">
<span class="material-symbols-outlined">light_mode</span>
</div>
<div>
<div class="font-label-md text-label-md text-on-surface"><span class="lang-en">Light / Dark Mode</span><span class="lang-tr">Aydınlık / Karanlık Mod</span></div>
<div class="font-label-sm text-label-sm text-on-surface-variant"><span class="lang-en">Switch interface theme styling</span><span class="lang-tr">Arayüz tema stilini değiştirin</span></div>
</div>
</div>
<div onclick="toggleDarkModePreference()" class="w-12 h-6 bg-primary rounded-full relative cursor-pointer">
<div id="dark-mode-indicator" class="absolute right-1 top-1 w-4 h-4 bg-white rounded-full transition-all"></div>
</div>
</div>
</div>
<hr class="border-outline-variant/30"/>
<div>
<h2 class="font-h3 text-h3 text-on-surface mb-xs"><span class="lang-en">Notifications</span><span class="lang-tr">Bildirimler</span></h2>
<p class="font-body-md text-body-md text-on-surface-variant mb-md"><span class="lang-en">Control how and when you receive updates.</span><span class="lang-tr">Güncellemeleri nasıl ve ne zaman alacağınızı kontrol edin.</span></p>
<div class="space-y-xs">
                    <div class="flex items-center justify-between p-sm hover:bg-surface-container-low rounded-lg transition-colors">
                        <div>
                            <div class="font-label-md text-label-md text-on-surface"><span class="lang-en">Email Notifications</span><span class="lang-tr">E-posta Bildirimleri</span></div>
                            <div class="font-label-sm text-label-sm text-on-surface-variant"><span class="lang-en">Grades, announcements, and system alerts</span><span class="lang-tr">Notlar, duyurular ve sistem uyarıları</span></div>
                        </div>
                        <div onclick="toggleSwitch(this)" class="w-12 h-6 @(Model.EmailNotificationsEnabled ? "bg-primary" : "bg-outline-variant") rounded-full relative cursor-pointer" data-active="@(Model.EmailNotificationsEnabled ? "true" : "false")" data-type="email">
                            <div class="switch-indicator absolute @(Model.EmailNotificationsEnabled ? "right-1" : "left-1") top-1 w-4 h-4 bg-white rounded-full transition-all"></div>
                        </div>
                    </div>
                    <div class="flex items-center justify-between p-sm hover:bg-surface-container-low rounded-lg transition-colors">
                        <div>
                            <div class="font-label-md text-label-md text-on-surface"><span class="lang-en">SMS Alerts</span><span class="lang-tr">SMS Uyarıları</span></div>
                            <div class="font-label-sm text-label-sm text-on-surface-variant"><span class="lang-en">Urgent university wide broadcasts</span><span class="lang-tr">Acil üniversite geneli duyurular</span></div>
                        </div>
                        <div onclick="toggleSwitch(this)" class="w-12 h-6 @(Model.SmsNotificationsEnabled ? "bg-primary" : "bg-outline-variant") rounded-full relative cursor-pointer" data-active="@(Model.SmsNotificationsEnabled ? "true" : "false")" data-type="sms">
                            <div class="switch-indicator absolute @(Model.SmsNotificationsEnabled ? "right-1" : "left-1") top-1 w-4 h-4 bg-white rounded-full transition-all"></div>
                        </div>
                    </div>
                </div>
            </div>
            <hr class="border-outline-variant/30"/>
            <div>
                <h2 class="font-h3 text-h3 text-on-surface mb-xs"><span class="lang-en">Language</span><span class="lang-tr">Dil</span></h2>
                <div class="w-full md:w-1/2">
                    <select id="select-language" onchange="changeLanguage(this)" class="w-full bg-surface-container-low border border-outline-variant/50 rounded-lg px-sm py-sm font-body-md text-body-md text-on-surface focus:ring-2 focus:ring-primary focus:border-primary transition-shadow appearance-none">
                        @if (Model.LanguagePreference == "en")
                        {
                            <option value="en" selected="selected">English</option>
                            <option value="tr">Türkçe</option>
                        }
                        else
                        {
                            <option value="en">English</option>
                            <option value="tr" selected="selected">Türkçe</option>
                        }
                    </select>
                </div>
            </div>
</div>
</section>
<!-- Security Section -->
<section class="tab-content hidden animate-fade-in" id="section-security">
<div class="glass-panel rounded-xl p-md space-y-lg">
<div>
<h2 class="font-h3 text-h3 text-on-surface mb-xs"><span class="lang-en">Change Password</span><span class="lang-tr">Şifre Değiştir</span></h2>
<p class="font-body-md text-body-md text-on-surface-variant mb-md"><span class="lang-en">Ensure your account uses a strong, unique password.</span><span class="lang-tr">Hesabınızın güçlü ve benzersiz bir şifre kullandığından emin olun.</span></p>
<form id="form-password-change" onsubmit="updatePassword(event)" class="space-y-sm max-w-md">
<div>
<label class="block font-label-sm text-label-sm text-on-surface-variant mb-xs"><span class="lang-en">Current Password</span><span class="lang-tr">Mevcut Şifre</span></label>
<input id="current-pass" required class="w-full bg-surface-container-low border border-outline-variant/50 rounded-lg px-sm py-sm font-body-md text-body-md text-on-surface focus:ring-2 focus:ring-primary focus:border-primary transition-shadow" type="password"/>
</div>
<div>
<label class="block font-label-sm text-label-sm text-on-surface-variant mb-xs"><span class="lang-en">New Password</span><span class="lang-tr">Yeni Şifre</span></label>
<input id="new-pass" required class="w-full bg-surface-container-low border border-outline-variant/50 rounded-lg px-sm py-sm font-body-md text-body-md text-on-surface focus:ring-2 focus:ring-primary focus:border-primary transition-shadow" type="password"/>
</div>
<div>
<label class="block font-label-sm text-label-sm text-on-surface-variant mb-xs"><span class="lang-en">Confirm New Password</span><span class="lang-tr">Yeni Şifreyi Onayla</span></label>
<input id="confirm-pass" required class="w-full bg-surface-container-low border border-outline-variant/50 rounded-lg px-sm py-sm font-body-md text-body-md text-on-surface focus:ring-2 focus:ring-primary focus:border-primary transition-shadow" type="password"/>
</div>
<div class="pt-xs">
<button type="submit" class="bg-primary text-on-primary font-label-md text-label-md px-md py-sm rounded-lg hover:bg-primary/90 transition-colors shadow-sm active:scale-95">
                                            <span class="lang-en">Update Password</span><span class="lang-tr">Şifreyi Güncelle</span>
                                        </button>
</div>
</form>
</div>
<hr class="border-outline-variant/30"/>
<div>
<h2 class="font-h3 text-h3 text-on-surface mb-xs"><span class="lang-en">Two-Factor Authentication (2FA)</span><span class="lang-tr">İki Adımlı Doğrulama (2FA)</span></h2>
<p class="font-body-md text-body-md text-on-surface-variant mb-md"><span class="lang-en">Add an extra layer of security to your student account.</span><span class="lang-tr">Öğrenci hesabınıza ekstra bir güvenlik katmanı ekleyin.</span></p>
<div class="flex items-center justify-between p-sm border border-outline-variant/30 rounded-lg bg-surface-container-lowest">
<div class="flex items-center gap-sm">
<div class="w-10 h-10 rounded-full bg-error-container/20 flex items-center justify-center text-error">
<span class="material-symbols-outlined">shield_locked</span>
</div>
<div>
<div class="font-label-md text-label-md text-on-surface"><span class="lang-en">Authenticator App</span><span class="lang-tr">Doğrulayıcı Uygulama</span></div>
<div id="2fa-status-text" class="font-label-sm text-label-sm text-on-surface-variant"><span class="lang-en">Not configured</span><span class="lang-tr">Yapılandırılmadı</span></div>
</div>
</div>
<button id="btn-enable-2fa" onclick="toggle2FA()" class="border border-outline font-label-md text-label-md px-sm py-xs rounded-lg text-on-surface hover:bg-surface-container transition-colors">
                                        <span class="lang-en">Enable</span><span class="lang-tr">Etkinleştir</span>
                                    </button>
</div>
</div>
</div>
</section>
</div>
</div>
</div>

@section Scripts {
<script>
    function triggerPhotoUpload() {
        document.getElementById('profile-file-input').click();
    }

    function previewProfilePhoto(event) {
        const file = event.target.files[0];
        if (file) {
            const reader = new FileReader();
            reader.onload = function(e) {
                document.getElementById('profile-preview-img').src = e.target.result;
                alert('Profil fotoğrafı geçici olarak güncellendi (Dosya yüklendi).');
            }
            reader.readAsDataURL(file);
        }
    }

    function savePersonalInfo(e) {
        e.preventDefault();
        const firstName = document.getElementById('profile-first-name').value.trim();
        const lastName = document.getElementById('profile-last-name').value.trim();
        const email = document.getElementById('profile-email').value.trim();

        if (!firstName || !lastName || !email) {
            alert('Lütfen tüm alanları doldurunuz.');
            return;
        }

        const formData = new FormData();
        formData.append('firstName', firstName);
        formData.append('lastName', lastName);
        formData.append('email', email);

        fetch('/Settings/UpdateProfile', {
            method: 'POST',
            body: formData
        })
        .then(res => res.json())
        .then(data => {
            if (data.success) {
                // Update layout sidebar/header name if visible
                const sidebarName = document.querySelector('nav h2.text-sm.font-semibold');
                if (sidebarName) sidebarName.textContent = data.fullName;

                alert('Kişisel bilgileriniz başarıyla güncellendi!');
            } else {
                alert('Hata: ' + data.message);
            }
        })
        .catch(err => {
            console.error(err);
            alert('Bir hata oluştu.');
        });
    }

    function toggleDarkModePreference() {
        // Trigger layout's toggleDarkMode function
        if (typeof toggleDarkMode === 'function') {
            toggleDarkMode();
            updateDarkModeIndicator();
        } else {
            alert('Karanlık mod değiştirildi.');
        }
    }

    function updateDarkModeIndicator() {
        const indicator = document.getElementById('dark-mode-indicator');
        if (!indicator) return;
        const isDark = document.documentElement.classList.contains('dark');
        if (isDark) {
            indicator.style.transform = 'translateX(-24px)';
            indicator.parentElement.classList.remove('bg-primary');
            indicator.parentElement.classList.add('bg-slate-700');
        } else {
            indicator.style.transform = 'translateX(0)';
            indicator.parentElement.classList.remove('bg-slate-700');
            indicator.parentElement.classList.add('bg-primary');
        }
    }

    function toggleSwitch(el) {
        const isActive = el.getAttribute('data-active') === 'true';
        const indicator = el.querySelector('.switch-indicator');
        
        if (isActive) {
            el.setAttribute('data-active', 'false');
            el.classList.remove('bg-primary');
            el.classList.add('bg-outline-variant');
            indicator.style.transform = 'translateX(-24px)';
        } else {
            el.setAttribute('data-active', 'true');
            el.classList.remove('bg-outline-variant');
            el.classList.add('bg-primary');
            indicator.style.transform = 'translateX(0)';
        }
        
        if (typeof syncPreferences === 'function') {
            syncPreferences();
        } else {
            alert('Bildirim tercihiniz güncellendi.');
        }
    }

    function changeLanguage(select) {
        const lang = select.value;
        document.documentElement.setAttribute('lang', lang);
        localStorage.setItem('preferred-language', lang);
        document.cookie = `lang=${lang};path=/;max-age=31536000;samesite=lax`;
        
        if (typeof syncPreferences === 'function') {
            syncPreferences();
        } else {
            alert('Dil seçeneği güncellendi.');
        }
    }

    function updatePassword(e) {
        e.preventDefault();
        const currentPass = document.getElementById('current-pass').value;
        const newPass = document.getElementById('new-pass').value;
        const confirmPass = document.getElementById('confirm-pass').value;

        if (newPass !== confirmPass) {
            alert('Yeni şifreler uyuşmuyor.');
            return;
        }

        const formData = new FormData();
        formData.append('currentPassword', currentPass);
        formData.append('newPassword', newPass);
        formData.append('confirmPassword', confirmPass);

        fetch('/Settings/UpdatePassword', {
            method: 'POST',
            body: formData
        })
        .then(res => res.json())
        .then(data => {
            if (data.success) {
                alert(data.message || 'Şifreniz başarıyla değiştirildi!');
                document.getElementById('form-password-change').reset();
            } else {
                alert(data.message || 'Şifre değiştirilemedi.');
            }
        })
        .catch(err => {
            console.error(err);
            alert('Bir hata oluştu.');
        });
    }

    let is2FAEnabled = false;
    function toggle2FA() {
        const statusText = document.getElementById('2fa-status-text');
        const btn = document.getElementById('btn-enable-2fa');
        
        is2FAEnabled = !is2FAEnabled;
        if (is2FAEnabled) {
            statusText.textContent = "Enabled (Google Authenticator)";
            statusText.classList.remove('text-on-surface-variant');
            statusText.classList.add('text-secondary', 'font-bold');
            btn.textContent = "Disable";
            btn.className = "border border-error text-error font-label-md text-label-md px-sm py-xs rounded-lg hover:bg-error/10 transition-colors";
            alert('İki adımlı doğrulama (2FA) başarıyla etkinleştirildi.');
        } else {
            statusText.textContent = "Not configured";
            statusText.classList.remove('text-secondary', 'font-bold');
            statusText.classList.add('text-on-surface-variant');
            btn.textContent = "Enable";
            btn.className = "border border-outline font-label-md text-label-md px-sm py-xs rounded-lg text-on-surface hover:bg-surface-container transition-colors";
            alert('İki adımlı doğrulama (2FA) devre dışı bırakıldı.');
        }
    }

    function switchTab(tabId) {
        // Hide all sections
        document.querySelectorAll('.tab-content').forEach(el => {
            el.classList.add('hidden');
            el.classList.remove('block');
        });
        
        // Show target section
        const target = document.getElementById('section-' + tabId);
        if(target) {
            target.classList.remove('hidden');
            target.classList.add('block');
        }

        // Update button styles
        document.querySelectorAll('.tab-btn').forEach(btn => {
            if(btn.dataset.target === tabId) {
                btn.classList.add('bg-primary/10', 'text-primary');
                btn.classList.remove('text-on-surface-variant', 'hover:bg-surface-container/50');
                btn.querySelector('span').style.fontVariationSettings = "'FILL' 1";
            } else {
                btn.classList.remove('bg-primary/10', 'text-primary');
                btn.classList.add('text-on-surface-variant', 'hover:bg-surface-container/50');
                btn.querySelector('span').style.fontVariationSettings = "'FILL' 0";
            }
        });
    }

    // Init dark mode switch indicator alignment on load
    document.addEventListener('DOMContentLoaded', () => {
        updateDarkModeIndicator();
        // Setup initial transform transition for switch indicators
        document.querySelectorAll('.w-12 .absolute').forEach(el => {
            el.style.transition = 'all 0.2s ease';
        });
    });
</script>
}

