@model Student_Information_System.Models.Student
@{ ViewData["Title"] = "Tuition Payment"; }
@section Styles {
<style>
.ambient-shadow {
            box-shadow: 0 8px 32px 0 rgba(0, 0, 0, 0.05);
        }
        
        .input-glow:focus {
            box-shadow: 0 0 0 2px var(--color-primary);
        }
</style>
}

<div class="flex-grow p-gutter relative overflow-hidden w-full">
<div class="mb-lg">
<h2 class="font-h1-mobile md:font-h1 text-h1-mobile md:text-h1 text-on-surface mb-xs"><span class="lang-en">Tuition &amp; Payments</span><span class="lang-tr">Harç &amp; Ödemeler</span></h2>
<p class="font-body-lg text-body-lg text-on-surface-variant"><span class="lang-en">Manage your financial obligations and review transaction history.</span><span class="lang-tr">Finansal yükümlülüklerinizi yönetin ve işlem geçmişini inceleyin.</span></p>
</div>
<!-- Bento Grid Layout -->
<div class="grid grid-cols-1 lg:grid-cols-12 gap-md">
<!-- Current Balance Card (Span 8) -->
<div class="lg:col-span-8 glass-card rounded-xl p-md ambient-shadow flex flex-col justify-between relative overflow-hidden">
<div class="absolute top-0 right-0 p-md opacity-10 pointer-events-none">
<span class="material-symbols-outlined text-[120px]">account_balance</span>
</div>
<div class="z-10 mb-xl">
<div class="flex items-center gap-sm mb-xs">
<span class="material-symbols-outlined text-tertiary">warning</span>
<span class="font-label-md text-label-md text-on-surface-variant uppercase tracking-wider"><span class="lang-en">Current Debt</span><span class="lang-tr">Güncel Borç</span></span>
</div>
<h3 class="font-h1 text-h1 text-on-surface">₺ @Model.TuitionDebt.ToString("N2")</h3>
<p class="font-label-sm text-label-sm text-tertiary mt-xs"><span class="lang-en">Due by: 15 October 2024</span><span class="lang-tr">Son Ödeme: 15 Ekim 2024</span></p>
</div>
<div class="z-10 flex flex-wrap gap-sm">
    @if(Model.TuitionDebt > 0)
    {
        <form asp-action="PayTuition" method="post" class="inline">
            <button type="submit" class="bg-primary text-on-primary font-label-md text-label-md px-md py-sm rounded-lg hover:bg-primary-container hover:text-on-primary-container transition-colors shadow-sm flex items-center gap-xs">
                <span class="material-symbols-outlined text-[18px]">credit_card</span>
                <span class="lang-en">Pay Online</span><span class="lang-tr">Sanal Ödeme Yap</span>
            </button>
        </form>
    }
    else
    {
        <span class="bg-secondary text-on-secondary font-label-md text-label-md px-md py-sm rounded-lg flex items-center gap-xs">
            <span class="material-symbols-outlined text-[18px]">check_circle</span>
            <span class="lang-en">No Debt Found</span><span class="lang-tr">Borcunuz Bulunmamaktadır</span>
        </span>
    }
<button class="bg-transparent border border-primary text-primary font-label-md text-label-md px-md py-sm rounded-lg hover:bg-surface-container-low transition-colors flex items-center gap-xs">
<span class="material-symbols-outlined text-[18px]">download</span>
                            <span class="lang-en">Download Invoice</span><span class="lang-tr">Faturayı İndir</span>
                        </button>
</div>
</div>
<!-- Quick Bank Info (Span 4) -->
<div class="lg:col-span-4 glass-card rounded-xl p-md ambient-shadow">
<div class="flex items-center gap-sm mb-md pb-sm border-b border-outline-variant/30">
<span class="material-symbols-outlined text-secondary">account_balance_wallet</span>
<h4 class="font-h3 text-h3 text-on-surface"><span class="lang-en">Wire Transfer Info</span><span class="lang-tr">EFT/Havale Bilgileri</span></h4>
</div>
<div class="space-y-md">
<div>
<p class="font-label-sm text-label-sm text-on-surface-variant uppercase mb-xs"><span class="lang-en">Bank Name</span><span class="lang-tr">Banka Adı</span></p>
<p class="font-body-md text-body-md text-on-surface font-medium">Ziraat Bankası - Merkez Şube</p>
</div>
<div>
<p class="font-label-sm text-label-sm text-on-surface-variant uppercase mb-xs">IBAN</p>
<div class="flex items-center justify-between bg-surface-container-lowest p-sm rounded border border-outline-variant/30">
<code class="font-mono text-sm text-on-surface">TR12 3456 7890 1234 5678 90</code>
<button class="text-primary hover:text-primary-container" title="Copy IBAN">
<span class="material-symbols-outlined text-[18px]">content_copy</span>
</button>
</div>
</div>
<div class="bg-surface-container-low p-sm rounded-lg border border-primary/20 flex gap-sm items-start">
<span class="material-symbols-outlined text-primary text-[20px] mt-xs">info</span>
<p class="font-label-sm text-label-sm text-on-surface-variant"><span class="lang-en">Include your Student ID in the transfer description.</span><span class="lang-tr">Açıklama kısmına Öğrenci Numaranızı eklemeyi unutmayın.</span></p>
</div>
</div>
</div>
<!-- Secure Payment Form (Span 7) -->
<div class="lg:col-span-7 glass-card rounded-xl p-md ambient-shadow mt-md">
<div class="flex items-center gap-sm mb-lg">
<span class="material-symbols-outlined text-primary">lock</span>
<h4 class="font-h3 text-h3 text-on-surface"><span class="lang-en">Secure Credit Card Payment</span><span class="lang-tr">Güvenli Kredi Kartı Ödemesi</span></h4>
</div>
<form class="space-y-md">
<div>
<label class="block font-label-md text-label-md text-on-surface-variant mb-xs"><span class="lang-en">Amount to Pay (₺)</span><span class="lang-tr">Ödenecek Tutar (₺)</span></label>
<input class="w-full bg-surface-container-lowest border border-outline-variant/50 rounded-lg p-sm font-body-md text-body-md text-on-surface focus:outline-none input-glow transition-shadow" readonly="" type="text" value="@Model.TuitionDebt.ToString("N2")"/>
</div>
<div>
<label class="block font-label-md text-label-md text-on-surface-variant mb-xs"><span class="lang-en">Cardholder Name</span><span class="lang-tr">Kart Sahibinin Adı</span></label>
<input class="w-full bg-surface-container-lowest border border-outline-variant/50 rounded-lg p-sm font-body-md text-body-md text-on-surface focus:outline-none input-glow transition-shadow uppercase" placeholder="EMIR TARIK DEDE" data-tr-placeholder="EMİR TARIK DEDE" data-en-placeholder="EMIR TARIK DEDE" type="text"/>
</div>
<div>
<label class="block font-label-md text-label-md text-on-surface-variant mb-xs"><span class="lang-en">Card Number</span><span class="lang-tr">Kart Numarası</span></label>
<div class="relative">
<input class="w-full bg-surface-container-lowest border border-outline-variant/50 rounded-lg p-sm pl-xl font-body-md text-body-md text-on-surface focus:outline-none input-glow transition-shadow font-mono" placeholder="0000 0000 0000 0000" type="text"/>
<span class="material-symbols-outlined absolute left-sm top-1/2 -translate-y-1/2 text-outline">credit_card</span>
</div>
</div>
<div class="flex gap-md">
<div class="flex-1">
<label class="block font-label-md text-label-md text-on-surface-variant mb-xs"><span class="lang-en">Expiry Date</span><span class="lang-tr">Son Kullanma Tarihi</span></label>
<input class="w-full bg-surface-container-lowest border border-outline-variant/50 rounded-lg p-sm font-body-md text-body-md text-on-surface focus:outline-none input-glow transition-shadow font-mono text-center" placeholder="MM/YY" data-tr-placeholder="AA/YY" data-en-placeholder="MM/YY" type="text"/>
</div>
<div class="flex-1">
<label class="block font-label-md text-label-md text-on-surface-variant mb-xs">CVV</label>
<input class="w-full bg-surface-container-lowest border border-outline-variant/50 rounded-lg p-sm font-body-md text-body-md text-on-surface focus:outline-none input-glow transition-shadow font-mono text-center" maxlength="3" placeholder="123" type="text"/>
</div>
</div>
<div class="pt-sm border-t border-outline-variant/30 mt-md">
<button class="w-full bg-secondary text-on-secondary font-label-md text-label-md py-sm rounded-lg hover:bg-secondary-container hover:text-on-secondary-container transition-colors shadow-sm flex items-center justify-center gap-sm" type="button">
<span class="material-symbols-outlined">shield</span>
                                <span class="lang-en">Submit Payment securely</span><span class="lang-tr">Ödemeyi Güvenle Tamamla</span>
                            </button>
<p class="text-center font-label-sm text-label-sm text-outline mt-sm flex items-center justify-center gap-xs">
<span class="material-symbols-outlined text-[16px]">lock</span>
                                <span class="lang-en">256-bit SSL Encryption</span><span class="lang-tr">256-bit SSL Şifreleme</span>
                            </p>
</div>
</form>
</div>
<!-- Transaction History (Span 5) -->
<div class="lg:col-span-5 glass-card rounded-xl p-md ambient-shadow mt-md flex flex-col">
<div class="flex items-center justify-between mb-md pb-sm border-b border-outline-variant/30">
<h4 class="font-h3 text-h3 text-on-surface flex items-center gap-sm">
<span class="material-symbols-outlined">receipt_long</span>
                            <span class="lang-en">Recent Transactions</span><span class="lang-tr">Son İşlemler</span>
                        </h4>
<button type="button" class="text-primary font-label-sm text-label-sm hover:underline" onclick="event.preventDefault();"><span class="lang-en">View All</span><span class="lang-tr">Tümünü Gör</span></button>
</div>
<div class="space-y-sm flex-1 overflow-y-auto pr-xs">
<!-- Transaction Row -->
<div class="bg-surface-container-lowest p-sm rounded-lg border border-outline-variant/20 flex justify-between items-center hover:bg-surface-container-low transition-colors cursor-default">
<div class="flex items-center gap-sm">
<div class="w-10 h-10 rounded-full bg-secondary-container/30 flex items-center justify-center text-secondary">
<span class="material-symbols-outlined text-[20px]">check_circle</span>
</div>
<div>
<p class="font-label-md text-label-md text-on-surface"><span class="lang-en">Fall Semester Tuition</span><span class="lang-tr">Güz Dönemi Harcı</span></p>
<p class="font-label-sm text-label-sm text-on-surface-variant">12 Sep 2023</p>
</div>
</div>
<div class="text-right">
<p class="font-body-md text-body-md text-on-surface font-medium">₺ 4,000.00</p>
<span class="bg-secondary text-on-secondary text-[10px] px-2 py-0.5 rounded-full uppercase tracking-wider"><span class="lang-en">Paid</span><span class="lang-tr">Ödendi</span></span>
</div>
</div>
<!-- Transaction Row -->
<div class="bg-surface-container-lowest p-sm rounded-lg border border-outline-variant/20 flex justify-between items-center hover:bg-surface-container-low transition-colors cursor-default">
<div class="flex items-center gap-sm">
<div class="w-10 h-10 rounded-full bg-secondary-container/30 flex items-center justify-center text-secondary">
<span class="material-symbols-outlined text-[20px]">check_circle</span>
</div>
<div>
<p class="font-label-md text-label-md text-on-surface"><span class="lang-en">Library Fine</span><span class="lang-tr">Kütüphane Cezası</span></p>
<p class="font-label-sm text-label-sm text-on-surface-variant">05 May 2023</p>
</div>
</div>
<div class="text-right">
<p class="font-body-md text-body-md text-on-surface font-medium">₺ 50.00</p>
<span class="bg-secondary text-on-secondary text-[10px] px-2 py-0.5 rounded-full uppercase tracking-wider"><span class="lang-en">Paid</span><span class="lang-tr">Ödendi</span></span>
</div>
</div>
<!-- Transaction Row -->
<div class="bg-surface-container-lowest p-sm rounded-lg border border-outline-variant/20 flex justify-between items-center hover:bg-surface-container-low transition-colors cursor-default">
<div class="flex items-center gap-sm">
<div class="w-10 h-10 rounded-full bg-secondary-container/30 flex items-center justify-center text-secondary">
<span class="material-symbols-outlined text-[20px]">check_circle</span>
</div>
<div>
<p class="font-label-md text-label-md text-on-surface"><span class="lang-en">Spring Semester Tuition</span><span class="lang-tr">Bahar Dönemi Harcı</span></p>
<p class="font-label-sm text-label-sm text-on-surface-variant">10 Feb 2023</p>
</div>
</div>
<div class="text-right">
<p class="font-body-md text-body-md text-on-surface font-medium">₺ 4,000.00</p>
<span class="bg-secondary text-on-secondary text-[10px] px-2 py-0.5 rounded-full uppercase tracking-wider"><span class="lang-en">Paid</span><span class="lang-tr">Ödendi</span></span>
</div>
</div>
</div>
</div>
</div>
</div>

@section Scripts {
<script>

</script>
}
