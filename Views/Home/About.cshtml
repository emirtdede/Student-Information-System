@{ ViewData["Title"] = "About Us"; }

<div class="flex-grow p-gutter relative overflow-hidden w-full">
<!-- Hero Section -->
<section class="mb-xl relative rounded-xl overflow-hidden glass-panel p-lg md:p-xl flex flex-col justify-center items-start min-h-[300px]">
<div class="absolute inset-0 bg-gradient-to-br from-primary-container/20 to-surface-variant/50 -z-10"></div>
<div class="max-w-2xl relative z-10">
<span class="inline-block px-sm py-xs bg-primary/10 text-primary font-label-sm text-label-sm rounded-full mb-md tracking-widest uppercase">
    <span class="lang-tr">Dijital Dönüşüm</span>
    <span class="lang-en">Digital Transformation</span>
</span>
<h1 class="font-h1-mobile md:font-h1 text-h1-mobile md:text-h1 text-on-surface mb-md">
    <span class="lang-tr">Geleceğin Kampüsü<br/>Bugün Burada.</span>
    <span class="lang-en">Campus of the Future<br/>Is Here Today.</span>
</h1>
<p class="font-body-lg text-body-lg text-on-surface-variant mb-lg">
    <span class="lang-tr">OKÜ-OBS, Osmaniye Korkut Ata Üniversitesi'nin akademik ve idari süreçlerini tek bir çatı altında toplayan, kullanıcı odaklı, şeffaf ve güvenli yeni nesil öğrenci bilgi sistemidir.</span>
    <span class="lang-en">OKU-OBS is a user-centric, transparent, and secure next-generation student information system that brings together the academic and administrative processes of Osmaniye Korkut Ata University under a single roof.</span>
</p>
</div>
<div class="absolute right-0 bottom-0 opacity-10 pointer-events-none -z-10 w-2/3 h-full mix-blend-multiply dark:mix-blend-screen">
<!-- Decorative abstract pattern instead of an image to keep HTML clean -->
<svg class="w-full h-full text-primary" viewbox="0 0 200 200" xmlns="http://www.w3.org/2000/svg">
<path d="M45.7,-76.4C58.9,-69.3,69.1,-56.3,77.7,-42.4C86.3,-28.5,93.3,-14.2,93.4,0.1C93.5,14.3,86.6,28.7,77.8,42.2C69,55.8,58.3,68.6,44.9,76.5C31.5,84.4,15.7,87.4,-0.4,88.1C-16.5,88.8,-33.1,87.2,-46.8,79.6C-60.6,72.1,-71.6,58.5,-79.8,43.5C-88,28.5,-93.4,12.2,-91.3,-3.3C-89.2,-18.7,-79.6,-33.3,-68.8,-45.5C-57.9,-57.8,-45.8,-67.7,-32.4,-74.6C-19.1,-81.6,-4.5,-85.7,10.6,-83.4C25.7,-81.1,51.4,-72.5,45.7,-76.4Z" fill="currentColor" transform="translate(100 100)"></path>
</svg>
</div>
</section>
<!-- Metrics Grid (Bento Style) -->
<section class="grid grid-cols-1 md:grid-cols-3 gap-md mb-xl">
<!-- Metric Card 1 -->
<div class="glass-panel rounded-xl p-md flex flex-col justify-between h-48 group hover:shadow-md transition-shadow">
<div class="flex justify-between items-start">
<div class="p-sm bg-primary/10 rounded-lg text-primary">
<span class="material-symbols-outlined" data-icon="groups" style="font-variation-settings: 'FILL' 1;">groups</span>
</div>
</div>
<div>
<h3 class="font-h2 text-h2 text-on-surface font-bold mb-xs group-hover:text-primary transition-colors">15.000+</h3>
<p class="font-label-md text-label-md text-on-surface-variant">
    <span class="lang-tr">Aktif Öğrenci</span>
    <span class="lang-en">Active Students</span>
</p>
</div>
</div>
<!-- Metric Card 2 -->
<div class="glass-panel rounded-xl p-md flex flex-col justify-between h-48 group hover:shadow-md transition-shadow">
<div class="flex justify-between items-start">
<div class="p-sm bg-secondary/10 rounded-lg text-secondary">
<span class="material-symbols-outlined" data-icon="local_library" style="font-variation-settings: 'FILL' 1;">local_library</span>
</div>
</div>
<div>
<h3 class="font-h2 text-h2 text-on-surface font-bold mb-xs group-hover:text-secondary transition-colors">850+</h3>
<p class="font-label-md text-label-md text-on-surface-variant">
    <span class="lang-tr">Akademik Danışman</span>
    <span class="lang-en">Academic Advisors</span>
</p>
</div>
</div>
<!-- Metric Card 3 -->
<div class="glass-panel rounded-xl p-md flex flex-col justify-between h-48 group hover:shadow-md transition-shadow">
<div class="flex justify-between items-start">
<div class="p-sm bg-tertiary/10 rounded-lg text-tertiary">
<span class="material-symbols-outlined" data-icon="integration_instructions" style="font-variation-settings: 'FILL' 1;">integration_instructions</span>
</div>
</div>
<div>
<h3 class="font-h2 text-h2 text-on-surface font-bold mb-xs group-hover:text-tertiary transition-colors">40+</h3>
<p class="font-label-md text-label-md text-on-surface-variant">
    <span class="lang-tr">Dijital Servis Entegrasyonu</span>
    <span class="lang-en">Digital Service Integrations</span>
</p>
</div>
</div>
</section>
<!-- Mission & History Split -->
<section class="grid grid-cols-1 lg:grid-cols-2 gap-md mb-xl">
<!-- History -->
<div class="glass-panel rounded-xl p-lg flex flex-col gap-md border-t-4 border-t-primary">
<div class="flex items-center gap-sm text-primary mb-sm">
<span class="material-symbols-outlined" data-icon="history">history</span>
<h2 class="font-h3 text-h3 font-semibold">
    <span class="lang-tr">Tarihçe ve Dönüşüm</span>
    <span class="lang-en">History and Transformation</span>
</h2>
</div>
<p class="font-body-md text-body-md text-on-surface-variant">
    <span class="lang-tr">2007 yılında kurulan Osmaniye Korkut Ata Üniversitesi, akademik birikimini dijital çağın gereksinimleriyle harmanlama vizyonunu benimsemiştir. OKÜ-OBS projesi, 2023 yılında başlayan "Sıfır Kağıt, Maksimum Verim" stratejisinin merkezinde yer almaktadır.</span>
    <span class="lang-en">Osmaniye Korkut Ata University, founded in 2007, has adopted the vision of blending its academic accumulation with the requirements of the digital age. The OKU-OBS project stands at the core of the "Zero Paper, Maximum Efficiency" strategy initiated in 2023.</span>
</p>
<p class="font-body-md text-body-md text-on-surface-variant">
    <span class="lang-tr">Eski monolitik sistemlerin yerini alan bu yeni nesil mimari, bulut tabanlı altyapısı sayesinde kesintisiz hizmet sunmayı hedeflerken, arayüz tasarımında sadelik ve işlevselliği ön planda tutmuştur.</span>
    <span class="lang-en">This next-generation architecture, which replaced legacy monolithic systems, aims to provide uninterrupted service through its cloud-based infrastructure while prioritizing simplicity and functionality in interface design.</span>
</p>
</div>
<!-- Mission -->
<div class="glass-panel rounded-xl p-lg flex flex-col gap-md border-t-4 border-t-secondary">
<div class="flex items-center gap-sm text-secondary mb-sm">
<span class="material-symbols-outlined" data-icon="track_changes">track_changes</span>
<h2 class="font-h3 text-h3 font-semibold">
    <span class="lang-tr">Misyonumuz</span>
    <span class="lang-en">Our Mission</span>
</h2>
</div>
<p class="font-body-md text-body-md text-on-surface-variant">
    <span class="lang-tr">Öğrencilerimizin ve akademisyenlerimizin bürokratik engellere takılmadan, yalnızca eğitim ve araştırmaya odaklanabilmeleri için pürüzsüz bir dijital deneyim sunmak.</span>
    <span class="lang-en">To provide a seamless digital experience so that our students and academicians can focus solely on education and research without being hindered by bureaucratic obstacles.</span>
</p>
<ul class="flex flex-col gap-sm mt-sm">
<li class="flex items-start gap-sm font-body-md text-body-md text-on-surface-variant">
<span class="material-symbols-outlined text-secondary mt-xs text-[18px]">check_circle</span>
    <span class="lang-tr">Kullanıcı dostu, sezgisel arayüz tasarımı.</span>
    <span class="lang-en">User-friendly, intuitive interface design.</span>
</li>
<li class="flex items-start gap-sm font-body-md text-body-md text-on-surface-variant">
<span class="material-symbols-outlined text-secondary mt-xs text-[18px]">check_circle</span>
    <span class="lang-tr">Gerçek zamanlı veri işleme ve anında bildirim altyapısı.</span>
    <span class="lang-en">Real-time data processing and instant notification infrastructure.</span>
</li>
<li class="flex items-start gap-sm font-body-md text-body-md text-on-surface-variant">
<span class="material-symbols-outlined text-secondary mt-xs text-[18px]">check_circle</span>
    <span class="lang-tr">Gelişmiş veri güvenliği ve KVKK uyumluluğu.</span>
    <span class="lang-en">Advanced data security and GDPR/KVKK compliance.</span>
</li>
</ul>
</div>
</section>
</div>

