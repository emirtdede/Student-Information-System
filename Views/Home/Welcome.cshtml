@{ Layout = null; }
<!DOCTYPE html>

<html lang="tr">
<head>
<meta charset="utf-8"/>
<meta content="width=device-width, initial-scale=1.0" name="viewport"/>
<title data-tr="OKÜ-OBS - Hoş Geldiniz" data-en="OKU-SIS - Welcome">OKÜ-OBS - Hoş Geldiniz</title>
<script>
    (function() {
        var t = localStorage.getItem('theme') || (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
        if (t === 'dark') {
            document.documentElement.setAttribute('data-theme', 'dark');
            document.documentElement.classList.add('dark');
        } else {
            document.documentElement.removeAttribute('data-theme');
            document.documentElement.classList.remove('dark');
        }
    })();
</script>
<script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
<link href="https://fonts.googleapis.com" rel="preconnect"/>
<link crossorigin="" href="https://fonts.gstatic.com" rel="preconnect"/>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;900&amp;display=swap" rel="stylesheet"/>
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet"/>
<script id="tailwind-config">
    tailwind.config = {
        darkMode: ['class', '[data-theme="dark"]'],
        theme: {
            extend: {
                colors: {
                    "primary": "#00647e",
                    "primary-container": "#007f9f",
                    "on-primary": "#ffffff",
                    "primary-fixed": "#baeaff",
                    "background": "#f8f9ff",
                    "on-background": "#0b1c30",
                    "surface-container-lowest": "#ffffff",
                    "on-surface": "#0b1c30",
                    "on-surface-variant": "#3e484d",
                    "outline-variant": "#bdc8ce",
                    "outline": "#6e797e",
                    "secondary": "#006c49",
                    "error": "#ba1a1a",
                    "inverse-primary": "#6cd3fa"
                },
                spacing: {
                    "xs": "4px", "sm": "12px", "md": "24px",
                    "lg": "40px", "xl": "64px", "gutter": "24px"
                },
                fontFamily: { "sans": ["Inter", "sans-serif"] }
            }
        }
    }
</script>
<style>
    *, *::before, *::after { box-sizing: border-box; }
    body { font-family: 'Inter', sans-serif; margin: 0; }
    .material-symbols-outlined { font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24; }

    /* Fluid background */
    .fluid-bg {
        background: linear-gradient(-45deg, #f8f9ff, #d3e4fe, #eff4ff, #cbdbf5);
        background-size: 400% 400%;
        animation: gradientBG 15s ease infinite;
    }
    @@keyframes gradientBG {
        0% { background-position: 0% 50%; }
        50% { background-position: 100% 50%; }
        100% { background-position: 0% 50%; }
    }
    .glass-card {
        background: rgba(255,255,255,0.72);
        backdrop-filter: blur(14px);
        -webkit-backdrop-filter: blur(14px);
        border: 1px solid rgba(255,255,255,0.5);
        box-shadow: 0 8px 32px rgba(0,0,0,0.07);
    }

    /* ======= DARK MODE ======= */
    [data-theme="dark"] body { background-color: #0f172a; color: #f1f5f9; }
    [data-theme="dark"] .fluid-bg {
        background: linear-gradient(-45deg, #0f172a, #1e293b, #0f172a, #1a2a40) !important;
    }
    [data-theme="dark"] .glass-card {
        background: rgba(15,23,42,0.85) !important;
        border: 1px solid rgba(255,255,255,0.08) !important;
    }
    [data-theme="dark"] label { color: #cbd5e1 !important; }
    [data-theme="dark"] p { color: #cbd5e1 !important; }
    [data-theme="dark"] a:not(.lang-pill button) { color: #6cd3fa !important; }
    [data-theme="dark"] a:not(.lang-pill button):hover { color: #baeaff !important; }
    [data-theme="dark"] h1, [data-theme="dark"] h2, [data-theme="dark"] h3 { color: #f1f5f9 !important; }
    [data-theme="dark"] .glass-card span:not(.material-symbols-outlined) { color: #cbd5e1 !important; }
    [data-theme="dark"] .glass-card .material-symbols-outlined { color: #cbd5e1 !important; }

    /* Explicit overrides for inline styled elements inside card */
    html[data-theme="dark"] .glass-card h1 { color: #baeaff !important; }
    html[data-theme="dark"] .glass-card h2 { color: #ffffff !important; }
    html[data-theme="dark"] .glass-card p { color: #cbd5e1 !important; }
    html[data-theme="dark"] .glass-card label { color: #cbd5e1 !important; }
    html[data-theme="dark"] .glass-card span:not(button span):not(.material-symbols-outlined) { color: #cbd5e1 !important; }
    html[data-theme="dark"] .glass-card .material-symbols-outlined { color: #94a3b8 !important; }
    html[data-theme="dark"] .glass-card a { color: #6cd3fa !important; }
    html[data-theme="dark"] .glass-card a:hover { color: #baeaff !important; }

    /* ======= NAVBAR ======= */
    #obs-topbar {
        width: 100%;
        position: sticky;
        top: 0;
        z-index: 100;
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 10px 24px;
        background: rgba(255,255,255,0.35);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        border-bottom: 1px solid rgba(0,0,0,0.07);
        gap: 12px;
    }
    [data-theme="dark"] #obs-topbar {
        background: rgba(15,23,42,0.8) !important;
        border-bottom-color: rgba(255,255,255,0.08) !important;
    }
    .topbar-brand {
        display: flex;
        align-items: center;
        gap: 8px;
        text-decoration: none;
        flex-shrink: 0;
    }
    .topbar-brand img { height: 36px; width: auto; }
    .topbar-brand-name {
        font-size: 17px;
        font-weight: 700;
        color: #00647e;
        letter-spacing: -0.3px;
    }
    [data-theme="dark"] .topbar-brand-name { color: #baeaff !important; }

    .topbar-right {
        display: flex;
        align-items: center;
        gap: 8px;
        flex-wrap: nowrap;
    }

    /* Language pill */
    .lang-pill {
        display: inline-flex;
        align-items: center;
        background: rgba(255,255,255,0.55);
        border: 1px solid rgba(0,100,126,0.22);
        border-radius: 999px;
        padding: 3px;
        gap: 2px;
        flex-shrink: 0;
    }
    [data-theme="dark"] .lang-pill {
        background: rgba(30,41,59,0.95) !important;
        border-color: rgba(255,255,255,0.14) !important;
    }
    .lang-pill button {
        border: none;
        border-radius: 999px;
        padding: 4px 11px;
        font-size: 12px;
        font-weight: 700;
        cursor: pointer;
        transition: all 0.16s;
        line-height: 1.3;
        font-family: 'Inter', sans-serif;
    }
    .lang-btn-active { background: #00647e; color: #fff; }
    .lang-btn-inactive { background: transparent; color: #6e797e; }
    [data-theme="dark"] .lang-btn-active { background: #004d62; color: #baeaff; }
    [data-theme="dark"] .lang-btn-inactive { background: transparent; color: #64748b; }

    /* Theme toggle */
    #theme-btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 36px;
        height: 36px;
        border-radius: 50%;
        border: 1px solid rgba(0,100,126,0.2);
        background: rgba(255,255,255,0.55);
        color: #3e484d;
        cursor: pointer;
        transition: all 0.16s;
        flex-shrink: 0;
    }
    #theme-btn:hover { background: rgba(0,100,126,0.12); color: #00647e; }
    [data-theme="dark"] #theme-btn {
        background: rgba(30,41,59,0.95) !important;
        color: #baeaff !important;
        border-color: rgba(255,255,255,0.14) !important;
    }
    [data-theme="dark"] #theme-btn:hover { background: rgba(186,234,255,0.1) !important; }
    #theme-btn .material-symbols-outlined { font-size: 20px; }

    /* Main layout */
    .page-wrap { min-height: 100vh; display: flex; flex-direction: column; }
    .main-content {
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 24px;
        flex: 1;
    }
    .card-wrap { width: 100%; max-width: 900px; }

    /* Portal option cards */
    .portal-card {
        border: 1px solid rgba(0, 100, 126, 0.12);
        background: rgba(255, 255, 255, 0.45);
        transition: all 0.2s ease;
        text-decoration: none;
    }
    .portal-card:hover {
        background: rgba(255, 255, 255, 0.8);
        border-color: #00647e;
        transform: translateY(-2px);
    }
    [data-theme="dark"] .portal-card {
        border-color: rgba(255, 255, 255, 0.08);
        background: rgba(30, 41, 59, 0.45);
    }
    [data-theme="dark"] .portal-card:hover {
        background: rgba(30, 41, 59, 0.8) !important;
        border-color: #6cd3fa !important;
    }

    /* Footer */
    .page-footer {
        padding: 20px 24px;
        display: flex;
        flex-wrap: wrap;
        justify-between: space-between;
        justify-content: space-between;
        align-items: center;
        gap: 12px;
        border-top: 1px solid rgba(0,0,0,0.07);
        font-size: 12px;
        color: #6e797e;
    }
    [data-theme="dark"] .page-footer {
        border-top-color: rgba(255,255,255,0.08) !important;
        color: #64748b !important;
    }
    .page-footer a { color: inherit; text-decoration: none; }
    .page-footer a:hover { color: #00647e; }
    [data-theme="dark"] .page-footer a:hover { color: #baeaff !important; }
    .footer-links { display: flex; gap: 16px; }
</style>
</head>
<body class="fluid-bg overflow-y-auto md:overflow-y-hidden">
<div class="page-wrap">

<!-- ===== TOP NAVIGATION BAR ===== -->
<nav id="obs-topbar">
    <a class="topbar-brand" href="/Home/Welcome">
        <img alt="OKÜ Logo" src="/profile.png"/>
        <span class="topbar-brand-name">OKÜ-OBS</span>
    </a>
    <div class="topbar-right">
        <div class="lang-pill" id="lang-pill">
            <button id="lang-tr-btn" class="lang-btn-active" onclick="changeLanguage('tr')">TR</button>
            <button id="lang-en-btn" class="lang-btn-inactive" onclick="changeLanguage('en')">EN</button>
        </div>
        <button id="theme-btn" onclick="toggleDarkMode()" title="Temayı değiştir">
            <span id="theme-icon" class="material-symbols-outlined">dark_mode</span>
        </button>
    </div>
</nav>

<!-- ===== MAIN CONTENT ===== -->
<div class="main-content">
<div class="card-wrap">
<div class="glass-card rounded-2xl p-10 md:p-12 flex flex-col items-center">
    <!-- Logo & Title -->
    <div style="display:flex;flex-direction:column;align-items:center;margin-bottom:32px;text-align:center;width:100%">
        <img alt="OKÜ-OBS Logo" src="/profile.png"
             style="width:110px;height:110px;object-fit:contain;border-radius:50%;padding:4px;background:rgba(0,100,126,0.06);margin-bottom:12px;"/>
        <h1 style="font-size:32px;font-weight:700;color:#00647e;margin:0 0 6px 0;letter-spacing:-0.4px;"
            data-tr="Hoş Geldiniz" data-en="Welcome">Hoş Geldiniz</h1>
        <p style="font-size:16px;color:#6e797e;margin:0;"
           data-tr="Osmaniye Korkut Ata Üniversitesi Öğrenci Bilgi Sistemi" data-en="Osmaniye Korkut Ata University Student Information System">Osmaniye Korkut Ata Üniversitesi Öğrenci Bilgi Sistemi</p>
    </div>

    <!-- Entrance Options -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 w-full mb-6">
        <!-- Student Entrance -->
        <a href="/Auth/Login" class="portal-card rounded-xl p-8 flex flex-col items-center text-center cursor-pointer decoration-none">
            <div class="w-16 h-16 rounded-full bg-primary/10 dark:bg-primary-fixed/10 flex items-center justify-center mb-4">
                <span class="material-symbols-outlined text-[36px] text-primary dark:text-primary-fixed">person</span>
            </div>
            <h2 style="font-size:20px;font-weight:700;color:#0b1c30;margin:0 0 8px 0;" data-tr="Öğrenci Girişi" data-en="Student Login">Öğrenci Girişi</h2>
            <p style="font-size:14px;color:#6e797e;margin:0;" data-tr="Ders seçimi, not görüntüleme ve akademik işlemler." data-en="Course selection, grade viewing, and academic operations.">Ders seçimi, not görüntüleme ve akademik işlemler.</p>
        </a>

        <!-- Advisor Entrance -->
        <a href="/AdvisorAuth/Login" class="portal-card rounded-xl p-8 flex flex-col items-center text-center cursor-pointer decoration-none">
            <div class="w-16 h-16 rounded-full bg-secondary/10 dark:bg-secondary-fixed/10 flex items-center justify-center mb-4">
                <span class="material-symbols-outlined text-[36px] text-secondary dark:text-secondary-fixed">badge</span>
            </div>
            <h2 style="font-size:20px;font-weight:700;color:#0b1c30;margin:0 0 8px 0;" data-tr="Danışman Girişi" data-en="Advisor Login">Danışman Girişi</h2>
            <p style="font-size:14px;color:#6e797e;margin:0;" data-tr="Öğrenci onayları, ders programları ve danışmanlık." data-en="Student approvals, course schedules, and academic advising.">Öğrenci onayları, ders programları ve danışmanlık.</p>
        </a>
    </div>

    <!-- Info Notice -->
    <div style="width: 100%; display: flex; gap: 12px; align-items: flex-start; padding: 16px; border-radius: 8px; background: rgba(0,100,126,0.05); border: 1px solid rgba(0,100,126,0.1);">
        <span class="material-symbols-outlined text-primary dark:text-primary-fixed text-[22px]" style="margin-top: 1px;">info</span>
        <p style="font-size:14px;color:#3e484d;margin:0;line-height:1.4;" class="text-left">
            <span data-tr="Sisteme ilk kez giriş yapıyorsanız veya şifrenizi unuttuysanız, lütfen öğrenci işleri ile iletişime geçiniz veya " data-en="If you are logging in for the first time or forgot your password, please contact student affairs or follow the ">Sisteme ilk kez giriş yapıyorsanız veya şifrenizi unuttuysanız, lütfen öğrenci işleri ile iletişime geçiniz veya </span>
            <a href="/Auth/ForgotPassword" style="font-weight: 600; text-decoration: underline;" data-tr="şifre sıfırlama" data-en="password reset">şifre sıfırlama</a>
            <span data-tr=" adımlarını takip ediniz." data-en=" steps."> adımlarını takip ediniz.</span>
        </p>
    </div>
</div>
</div>
</div>

<!-- ===== FOOTER ===== -->
<footer class="page-footer">
    <div data-tr="© @DateTime.Now.Year Osmaniye Korkut Ata Üniversitesi. Tüm hakları saklıdır. Geliştirici: Emir Tarık Dede." data-en="© @DateTime.Now.Year Osmaniye Korkut Ata University. All rights reserved. Developer: Emir Tarık Dede.">
        © @DateTime.Now.Year Osmaniye Korkut Ata Üniversitesi. Tüm hakları saklıdır. Geliştirici: Emir Tarık Dede.
    </div>
    <div class="footer-links">
        <a href="/Support/PrivacyPolicy" data-tr="Gizlilik Politikası" data-en="Privacy Policy">Gizlilik Politikası</a>
        <a href="/Support/TermsOfUse" data-tr="Kullanım Şartları" data-en="Terms of Service">Kullanım Şartları</a>
        <a href="/Support/HelpCenter" data-tr="Destek" data-en="Support">Destek</a>
    </div>
</footer>

</div><!-- .page-wrap -->
<script>
    // ===== THEME =====
    function toggleDarkMode() {
        var isDark = document.documentElement.getAttribute('data-theme') === 'dark';
        if (isDark) {
            document.documentElement.removeAttribute('data-theme');
            document.documentElement.classList.remove('dark');
            localStorage.setItem('theme', 'light');
        } else {
            document.documentElement.setAttribute('data-theme', 'dark');
            document.documentElement.classList.add('dark');
            localStorage.setItem('theme', 'dark');
        }
        updateThemeIcon();
    }
    function updateThemeIcon() {
        var icon = document.getElementById('theme-icon');
        if (!icon) return;
        var isDark = document.documentElement.getAttribute('data-theme') === 'dark';
        icon.textContent = isDark ? 'light_mode' : 'dark_mode';
    }

    // ===== LANGUAGE =====
    function changeLanguage(lang) {
        localStorage.setItem('lang', lang);
        document.querySelectorAll('[data-tr]').forEach(function(el) {
            el.textContent = lang === 'en' ? el.getAttribute('data-en') : el.getAttribute('data-tr');
        });
        // Update button styles
        var trBtn = document.getElementById('lang-tr-btn');
        var enBtn = document.getElementById('lang-en-btn');
        if (trBtn && enBtn) {
            if (lang === 'en') {
                trBtn.className = 'lang-btn-inactive';
                enBtn.className = 'lang-btn-active';
            } else {
                trBtn.className = 'lang-btn-active';
                enBtn.className = 'lang-btn-inactive';
            }
        }
    }

    // ===== INIT =====
    document.addEventListener('DOMContentLoaded', function() {
        updateThemeIcon();
        changeLanguage(localStorage.getItem('lang') || 'tr');
    });
</script>
</body>
</html>