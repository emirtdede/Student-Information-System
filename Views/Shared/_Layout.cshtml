@{
    var langCookie = Context.Request.Cookies["lang"] ?? "tr";
    var themeCookie = Context.Request.Cookies["theme"] ?? "light";
}
<!DOCTYPE html>
<html class="@themeCookie" lang="@langCookie">
<head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <title>@ViewData["Title"] - OKÜ OBS</title>
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;900&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />
    
    <script id="tailwind-config">
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    "colors": {
                        "surface-container-high": "#dce9ff",
                        "error-container": "#ffdad6",
                        "on-surface-variant": "#3e484d",
                        "outline": "#6e797e",
                        "on-primary-fixed": "#001f29",
                        "surface-container": "#e5eeff",
                        "on-tertiary-fixed": "#410004",
                        "surface-bright": "#f8f9ff",
                        "surface-container-lowest": "#ffffff",
                        "secondary-fixed": "#6ffbbe",
                        "surface-container-low": "#eff4ff",
                        "on-error-container": "#93000a",
                        "on-primary-container": "#fafdff",
                        "inverse-primary": "#6cd3fa",
                        "surface-variant": "#d3e4fe",
                        "surface-tint": "#006781",
                        "surface-dim": "#cbdbf5",
                        "on-secondary-fixed-variant": "#005236",
                        "primary-fixed": "#baeaff",
                        "primary": "var(--color-primary)",
                        "secondary-container": "#6cf8bb",
                        "outline-variant": "#bdc8ce",
                        "surface": "#f8f9ff",
                        "tertiary": "var(--color-tertiary)",
                        "on-error": "#ffffff",
                        "on-surface": "#0b1c30",
                        "on-secondary-fixed": "#002113",
                        "on-tertiary-fixed-variant": "#930013",
                        "tertiary-container": "#da3437",
                        "on-primary-fixed-variant": "#004d62",
                        "tertiary-fixed-dim": "#ffb3ad",
                        "on-background": "#0b1c30",
                        "secondary": "var(--color-secondary)",
                        "secondary-fixed-dim": "#4edea3",
                        "background": "#f8f9ff",
                        "error": "#ba1a1a",
                        "primary-fixed-dim": "#6cd3fa",
                        "on-secondary-container": "#00714d",
                        "on-primary": "var(--color-on-primary)",
                        "surface-container-highest": "#d3e4fe",
                        "inverse-surface": "#213145",
                        "on-tertiary-container": "#fffbff",
                        "on-secondary": "var(--color-on-secondary)",
                        "primary-container": "#007f9f",
                        "tertiary-fixed": "#ffdad7"
                    },
                    "borderRadius": {
                        "DEFAULT": "0.25rem",
                        "lg": "0.5rem",
                        "xl": "0.75rem",
                        "full": "9999px"
                    },
                    "spacing": {
                        "gutter": "24px",
                        "xl": "64px",
                        "md": "24px",
                        "base": "8px",
                        "lg": "40px",
                        "xs": "4px",
                        "sm": "12px",
                        "container-max": "1280px"
                    },
                    "fontFamily": {
                        "h2": ["Inter"],
                        "body-lg": ["Inter"],
                        "label-md": ["Inter"],
                        "h1-mobile": ["Inter"],
                        "h1": ["Inter"],
                        "body-md": ["Inter"],
                        "h3": ["Inter"],
                        "label-sm": ["Inter"]
                    },
                    "fontSize": {
                        "h2": ["30px", { "lineHeight": "36px", "letterSpacing": "-0.01em", "fontWeight": "600" }],
                        "body-lg": ["18px", { "lineHeight": "28px", "fontWeight": "400" }],
                        "label-md": ["14px", { "lineHeight": "20px", "letterSpacing": "0.01em", "fontWeight": "500" }],
                        "h1-mobile": ["32px", { "lineHeight": "38px", "letterSpacing": "-0.02em", "fontWeight": "700" }],
                        "h1": ["40px", { "lineHeight": "48px", "letterSpacing": "-0.02em", "fontWeight": "700" }],
                        "body-md": ["16px", { "lineHeight": "24px", "fontWeight": "400" }],
                        "h3": ["24px", { "lineHeight": "32px", "fontWeight": "600" }],
                        "label-sm": ["12px", { "lineHeight": "16px", "letterSpacing": "0.05em", "fontWeight": "600" }]
                    }
                }
            }
        }
    </script>
    <style>
        :root {
            --color-primary: #00647e;
            --color-on-primary: #ffffff;
            --color-secondary: #006c49;
            --color-on-secondary: #ffffff;
            --color-tertiary: #b61722;
            --color-on-tertiary: #ffffff;
        }

        body {
            background-color: #f8f9ff;
            background-image: radial-gradient(at 0% 0%, hsla(210,100%,95%,1) 0, transparent 50%), radial-gradient(at 50% 0%, hsla(190,100%,90%,1) 0, transparent 50%), radial-gradient(at 100% 0%, hsla(200,100%,92%,1) 0, transparent 50%);
            background-attachment: fixed;
            min-height: 100vh;
        }
        .glass-card {
            background: rgba(255, 255, 255, 0.7);
            backdrop-filter: blur(12px);
            -webkit-backdrop-filter: blur(12px);
            border: 1px solid rgba(255, 255, 255, 0.2);
            box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05), 0 2px 4px -1px rgba(0, 0, 0, 0.03);
            color: inherit;
        }
        
        .dark {
            --color-primary: #6cd3fa;
            --color-on-primary: #001f29;
            --color-secondary: #4edea3;
            --color-on-secondary: #002113;
            --color-tertiary: #ffb3ad;
            --color-on-tertiary: #410004;
        }

        .dark body {
            background-color: #000000;
            background-image: none;
            color: #d4d4d4;
        }
        .dark .bg-surface-container-lowest,
        .dark [class*="bg-surface-container-lowest/"] {
            background-color: rgba(10, 10, 10, 0.85) !important;
        }
        .dark .bg-surface-container-low,
        .dark [class*="bg-surface-container-low/"] {
            background-color: rgba(18, 18, 18, 0.85) !important;
        }
        .dark .bg-surface-container,
        .dark [class*="bg-surface-container/"] {
            background-color: rgba(26, 26, 26, 0.85) !important;
        }
        .dark .bg-surface-container-high,
        .dark [class*="bg-surface-container-high/"] {
            background-color: rgba(38, 38, 38, 0.9) !important;
        }
        .dark .bg-surface-container-highest,
        .dark [class*="bg-surface-container-highest/"] {
            background-color: rgba(50, 50, 50, 0.9) !important;
        }
        .dark .bg-surface,
        .dark [class*="bg-surface/"],
        .dark .bg-surface-bright,
        .dark [class*="bg-surface-bright/"] {
            background-color: rgba(10, 10, 10, 0.85) !important;
        }
        .dark .bg-white\/70 {
            background-color: rgba(18, 18, 18, 0.8) !important;
        }
        .dark .text-on-surface,
        .dark .text-on-background,
        .dark h1, .dark h2, .dark h3, .dark h4 {
            color: #f5f5f5 !important;
        }
        .dark .text-on-surface-variant {
            color: #a3a3a3 !important;
        }
        .dark .glass-card {
            background: rgba(18, 18, 18, 0.85);
            border: 1px solid rgba(255, 255, 255, 0.08);
            box-shadow: 0 4px 30px rgba(0, 0, 0, 0.5);
            color: #e5e5e5;
        }
        .dark nav {
            background-color: #050505 !important;
            border-color: rgba(255,255,255,0.1) !important;
        }
        .dark input, .dark textarea, .dark select {
            background-color: #1a1a1a !important;
            color: #fff !important;
            border-color: rgba(255, 255, 255, 0.15) !important;
        }
        .dark .glass-card:hover {
            background: rgba(30, 30, 30, 0.95) !important;
            box-shadow: 0 8px 24px 0 rgba(0, 0, 0, 0.5) !important;
        }
        .dark [class*="hover:bg-white/"]:hover {
            background-color: rgba(255, 255, 255, 0.08) !important;
        }
        .accordion-content {
            transition: max-height 0.3s ease-in-out, opacity 0.3s ease-in-out;
            max-height: 0;
            opacity: 0;
            overflow: hidden;
        }
        .accordion-content.expanded {
            max-height: 1000px; /* Arbitrary large number */
            opacity: 1;
        }
        .accordion-icon {
            transition: transform 0.3s ease;
        }
        .expanded .accordion-icon {
            transform: rotate(180deg);
        }
        html[lang="en"] .lang-tr { display: none !important; }
        html[lang="tr"] .lang-en { display: none !important; }

        /* Toast Notifications */
        .toast {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 16px;
            border-radius: 12px;
            background: rgba(255, 255, 255, 0.85);
            backdrop-filter: blur(12px);
            -webkit-backdrop-filter: blur(12px);
            border: 1px solid rgba(255, 255, 255, 0.4);
            box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.05), 0 4px 6px -2px rgba(0, 0, 0, 0.05);
            transform: translateX(120%);
            transition: all 0.35s cubic-bezier(0.16, 1, 0.3, 1);
            pointer-events: auto;
            color: #0b1c30;
        }
        .dark .toast {
            background: rgba(18, 18, 18, 0.85) !important;
            border: 1px solid rgba(255, 255, 255, 0.08) !important;
            color: #f5f5f5 !important;
        }
        .toast.show {
            transform: translateX(0);
        }
        .toast-success {
            border-left: 4px solid #006c49;
        }
        .dark .toast-success {
            border-left: 4px solid #4edea3;
        }
        .toast-error {
            border-left: 4px solid #b61722;
        }
        .dark .toast-error {
            border-left: 4px solid #ffb3ad;
        }
        .toast-info {
            border-left: 4px solid #00647e;
        }
        .dark .toast-info {
            border-left: 4px solid #6cd3fa;
        }

        /* Collapsible Sidebar Styles */
        #desktop-sidebar {
            transition: transform 0.3s cubic-bezier(0.16, 1, 0.3, 1);
        }
        #desktop-sidebar.collapsed {
            transform: translateX(-100%);
        }
        main#main-content {
            transition: margin-left 0.3s cubic-bezier(0.16, 1, 0.3, 1);
        }
        main#main-content.sidebar-collapsed {
            margin-left: 40px !important;
        }

        #sidebar-open-btn {
            background-color: var(--color-primary) !important;
            color: var(--color-on-primary) !important;
        }
        .dark #sidebar-open-btn {
            background-color: var(--color-primary) !important;
            color: #0f172a !important;
        }
        #sidebar-open-btn span {
            color: inherit !important;
        }
    </style>
    @RenderSection("Styles", required: false)
</head>
<body class="text-on-background font-body-md text-body-md flex flex-col md:flex-row relative antialiased min-h-screen">

    <!-- Ambient Background Decor -->
    <div class="fixed inset-0 z-[-1] pointer-events-none overflow-hidden">
        <div class="absolute top-[-10%] left-[-10%] w-[40%] h-[40%] bg-primary/5 rounded-full blur-3xl"></div>
        <div class="absolute bottom-[-10%] right-[-5%] w-[50%] h-[50%] bg-secondary/5 rounded-full blur-3xl"></div>
