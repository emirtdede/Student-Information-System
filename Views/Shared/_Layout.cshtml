                    </li>
                    <li>
                        <a class="flex items-center gap-xs px-2 py-1 rounded-md text-[13px] @(ViewContext.RouteData.Values["controller"]?.ToString() == "Advisor" && ViewContext.RouteData.Values["action"]?.ToString() == "CourseApproval" ? "text-primary dark:text-primary-fixed font-bold border-r-4 border-primary dark:border-primary-fixed bg-surface-container/50 translate-x-1" : "text-on-surface-variant dark:text-outline-variant hover:text-primary hover:bg-surface-container-low/50") transition-all duration-200" href="/Advisor/CourseApproval">
