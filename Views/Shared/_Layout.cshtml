    <script>
        function toggleDarkMode() {
            document.documentElement.classList.toggle('dark');
            const isDark = document.documentElement.classList.contains('dark');
            const newTheme = isDark ? 'dark' : 'light';
            localStorage.setItem('theme', newTheme);
            document.cookie = `theme=${newTheme};path=/;max-age=31536000;samesite=lax`;

            if (document.querySelector('a[href="/Auth/Logout"]')) {
                syncPreferences();
            }
        }

        // Apply theme on load
        const storedTheme = localStorage.getItem('theme') || "@themeCookie";
        if (storedTheme === 'dark') {
            document.documentElement.classList.add('dark');
            document.documentElement.classList.remove('light');
        } else {
            document.documentElement.classList.remove('dark');
            document.documentElement.classList.add('light');
        }

        // Language Toggle Logic
        function toggleLanguage() {
            let currentLang = document.documentElement.getAttribute('lang') || 'tr';
            let newLang = currentLang === 'tr' ? 'en' : 'tr';
            document.documentElement.setAttribute('lang', newLang);
            localStorage.setItem('preferred-language', newLang);
            document.cookie = `lang=${newLang};path=/;max-age=31536000;samesite=lax`;
            updatePlaceholders(newLang);

            if (document.querySelector('a[href="/Auth/Logout"]')) {
                syncPreferences();
            } else {
                location.reload();
            }
        }

        function syncPreferences() {
            const isDark = document.documentElement.classList.contains('dark');
            const theme = isDark ? 'dark' : 'light';
            const lang = document.documentElement.getAttribute('lang') || 'tr';

            const emailNotifyEl = document.querySelector('[onclick*="toggleSwitch"][data-type="email"]');
            const smsNotifyEl = document.querySelector('[onclick*="toggleSwitch"][data-type="sms"]');

            const emailNotify = emailNotifyEl ? (emailNotifyEl.getAttribute('data-active') === 'true') : true;
            const smsNotify = smsNotifyEl ? (smsNotifyEl.getAttribute('data-active') === 'true') : false;

            const formData = new FormData();
            formData.append('emailNotificationsEnabled', emailNotify);
            formData.append('smsNotificationsEnabled', smsNotify);
            formData.append('themePreference', theme);
            formData.append('languagePreference', lang);

            fetch('/Settings/UpdatePreferences', {
                method: 'POST',
                body: formData
            })
            .then(res => res.json())
            .then(data => {
                if (data.success) {
                    if (typeof updateDarkModeIndicator === 'function') {
                        updateDarkModeIndicator();
                    }
                    if (lang !== localStorage.getItem('last-synced-lang')) {
                        localStorage.setItem('last-synced-lang', lang);
                        location.reload();
                    }
                }
            })
            .catch(err => console.error('Error syncing preferences:', err));
        }

        function updatePlaceholders(lang) {
            const searchInput = document.getElementById('global-search-input');
            if (searchInput) {
                searchInput.placeholder = searchInput.getAttribute('data-lang-' + lang + '-placeholder');
            }
        }

        // Apply language on load
        let savedLang = localStorage.getItem('preferred-language') || "@langCookie";
        document.documentElement.setAttribute('lang', savedLang);
        updatePlaceholders(savedLang);

        // Toast Notification System
        function showNotification(message, type = 'success') {
            const container = document.getElementById('toast-container');
            if (!container) return;

            const toast = document.createElement('div');
            toast.className = `toast toast-${type} shadow-lg`;

            let iconName = 'check_circle';
            let iconColor = 'text-secondary dark:text-primary-fixed';
            if (type === 'error') {
                iconName = 'error';
                iconColor = 'text-tertiary';
            } else if (type === 'info') {
                iconName = 'info';
                iconColor = 'text-primary';
            }

            toast.innerHTML = `
                <span class="material-symbols-outlined ${iconColor}" style="font-variation-settings: 'FILL' 1;">${iconName}</span>
                <span class="font-body-md flex-1 text-sm font-medium">${message}</span>
                <button class="text-on-surface-variant/50 hover:text-on-surface-variant transition-colors flex items-center" onclick="this.parentElement.remove()">
                    <span class="material-symbols-outlined text-[18px]">close</span>
                </button>
            `;

            container.appendChild(toast);

            // Trigger animation
            setTimeout(() => toast.classList.add('show'), 50);

            // Auto dismiss
            setTimeout(() => {
                toast.classList.remove('show');
                setTimeout(() => toast.remove(), 350);
            }, 4000);
        }

        // Global alert wrapper
        window.alert = function(msg) {
            const isError = msg.toLowerCase().includes('hata') || 
                            msg.toLowerCase().includes('error') || 
                            msg.toLowerCase().includes('uyuşmuyor') || 
                            msg.toLowerCase().includes('bulunamadı') || 
                            msg.toLowerCase().includes('geçersiz') || 
                            msg.toLowerCase().includes('doldurunuz') ||
                            msg.toLowerCase().includes('seçiniz');
            showNotification(msg, isError ? 'error' : 'success');
        };

        // Collapsible Sidebar Functions
        function toggleSidebar(show) {
            const sidebar = document.getElementById('desktop-sidebar');
            const mainContent = document.getElementById('main-content');
            const openBtn = document.getElementById('sidebar-open-btn');
            
            if (!sidebar || !mainContent) return;

            if (show) {
                sidebar.classList.remove('collapsed');
                mainContent.classList.remove('sidebar-collapsed');
                if (openBtn) openBtn.classList.add('hidden');
                localStorage.setItem('sidebar-collapsed', 'false');
            } else {
                sidebar.classList.add('collapsed');
                mainContent.classList.add('sidebar-collapsed');
                if (openBtn) openBtn.classList.remove('hidden');
                localStorage.setItem('sidebar-collapsed', 'true');
            }
        }

        // Apply sidebar state on load
        document.addEventListener('DOMContentLoaded', () => {
            const isCollapsed = localStorage.getItem('sidebar-collapsed') === 'true';
            if (isCollapsed && window.innerWidth >= 1024) {
                toggleSidebar(false);
            }
        });
    </script>
    <div id="toast-container" class="fixed top-24 right-6 z-[9999] flex flex-col gap-3 max-w-sm w-full pointer-events-none"></div>
    @RenderSection("Scripts", required: false)
