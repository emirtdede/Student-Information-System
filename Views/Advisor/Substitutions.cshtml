@model List<Student_Information_System.Models.SubstitutionRequest>
@{
    ViewData["Title"] = "Ders Muafiyet Talepleri";
}

<div class="flex-grow p-gutter relative overflow-hidden w-full">
    <!-- Page Header -->
    <div class="flex flex-col md:flex-row justify-between items-start md:items-end gap-md mb-lg">
        <div>
            <h1 class="font-h1 text-h1 text-on-surface"><span class="lang-en">Course Exemption &amp; Adaptation Approvals</span><span class="lang-tr">Ders Muafiyet ve İntibak Onayları</span></h1>
            <p class="font-body-md text-body-md text-on-surface-variant mt-xs"><span class="lang-en">Course exemption and adaptation requests submitted by your students.</span><span class="lang-tr">Öğrencileriniz tarafından gönderilen ders muafiyet ve intibak talepleri.</span></p>
        </div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="bg-secondary/10 border border-secondary/30 text-secondary p-md rounded-xl mb-md font-body-md flex items-center gap-sm">
            <span class="material-symbols-outlined text-secondary">check_circle</span>
            @TempData["SuccessMessage"]
        </div>
    }

    <!-- Pending Requests List -->
    <div class="glass-card rounded-xl p-md flex flex-col mb-gutter">
        <h3 class="font-h3 text-h3 text-on-surface mb-md"><span class="lang-en">Pending Approval Requests</span><span class="lang-tr">Onay Bekleyen Talepler</span></h3>

        @{
            var pendingRequests = Model.Where(r => r.Status == "Pending").ToList();
            var processedRequests = Model.Where(r => r.Status != "Pending").ToList();
        }

        @if (pendingRequests.Count > 0)
        {
            <div class="flex flex-col gap-md">
                @foreach (var req in pendingRequests)
                {
                    <div class="glass-card p-md rounded-xl border border-outline-variant/20 flex flex-col md:flex-row justify-between items-start md:items-center gap-md">
                        <div class="flex-grow">
                            <div class="flex items-center gap-sm mb-2">
                                <span class="font-label-md text-label-md text-primary font-bold">@req.Student.FirstName @req.Student.LastName</span>
                                <span class="text-xs text-outline">(@req.Student.StudentNumber)</span>
                                <span class="text-xs text-outline">&bull;</span>
                                <span class="text-xs text-outline">@req.RequestDate.ToString("dd MMM yyyy HH:mm")</span>
                            </div>
                            
                            <div class="flex items-center gap-md bg-surface-bright p-sm rounded-lg border border-outline-variant/10">
                                <div>
                                    <div class="text-[11px] text-outline font-semibold uppercase"><span class="lang-en">Old Course</span><span class="lang-tr">Eski Ders</span></div>
                                    <div class="font-label-md text-label-md text-on-surface">@req.OldCourse.Code - @req.OldCourse.Name</div>
                                </div>
                                <span class="material-symbols-outlined text-outline">swap_horiz</span>
                                <div>
                                    <div class="text-[11px] text-outline font-semibold uppercase"><span class="lang-en">New Course</span><span class="lang-tr">Yeni Ders</span></div>
                                    <div class="font-label-md text-label-md text-on-surface">@req.NewCourse.Code - @req.NewCourse.Name</div>
                                </div>
                            </div>

                            <p class="text-[13px] text-on-surface-variant mt-sm leading-relaxed italic">
                                <strong><span class="lang-en">Reason:</span><span class="lang-tr">Gerekçe:</span></strong> "@req.Reason"
                            </p>
                        </div>
                        
                        <div class="flex gap-sm shrink-0 w-full md:w-auto">
                            <form method="post" asp-action="RejectSubstitution" class="m-0 flex-1 md:flex-none">
                                <input type="hidden" name="id" value="@req.Id" />
                                <button type="submit" class="w-full px-4 py-2 rounded-full border border-error text-error hover:bg-error/10 font-label-md text-label-md transition-all">
                                    <span class="lang-en">Reject</span><span class="lang-tr">Reddet</span>
                                </button>
                            </form>
                            <form method="post" asp-action="ApproveSubstitution" class="m-0 flex-1 md:flex-none">
                                <input type="hidden" name="id" value="@req.Id" />
                                <button type="submit" class="w-full px-4 py-2 rounded-full bg-secondary text-on-secondary hover:scale-105 transition-transform font-label-md text-label-md">
                                    <span class="lang-en">Approve</span><span class="lang-tr">Onayla</span>
                                </button>
                            </form>
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="py-lg text-center opacity-50 flex flex-col items-center">
                <span class="material-symbols-outlined text-[48px] mb-sm">task_alt</span>
                <p class="font-body-md text-body-md"><span class="lang-en">No pending course exemption requests.</span><span class="lang-tr">Onay bekleyen ders muafiyet talebi bulunmuyor.</span></p>
            </div>
        }
    </div>

    <!-- Processed Requests History -->
    <div class="glass-card rounded-xl p-md flex flex-col">
        <h3 class="font-h3 text-h3 text-on-surface mb-md"><span class="lang-en">Request History</span><span class="lang-tr">Talep Geçmişi</span></h3>

        @if (processedRequests.Count > 0)
        {
            <div class="overflow-x-auto">
                <table class="w-full text-left border-collapse">
                    <thead>
                        <tr class="border-b border-outline-variant/30">
                            <th class="py-sm px-md font-label-sm text-label-sm text-on-surface-variant uppercase"><span class="lang-en">Student</span><span class="lang-tr">Öğrenci</span></th>
                            <th class="py-sm px-md font-label-sm text-label-sm text-on-surface-variant uppercase"><span class="lang-en">Relation</span><span class="lang-tr">İlişki</span></th>
                            <th class="py-sm px-md font-label-sm text-label-sm text-on-surface-variant uppercase"><span class="lang-en">Status</span><span class="lang-tr">Durum</span></th>
                            <th class="py-sm px-md font-label-sm text-label-sm text-on-surface-variant uppercase"><span class="lang-en">Date</span><span class="lang-tr">Tarih</span></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var req in processedRequests)
                        {
                            <tr class="border-b border-outline-variant/10 hover:bg-surface-container-lowest/30 transition-colors">
                                <td class="py-sm px-md">
                                    <div class="font-label-md text-label-md text-on-surface">@req.Student.FirstName @req.Student.LastName</div>
                                    <div class="font-label-sm text-label-sm text-on-surface-variant">@req.Student.StudentNumber</div>
                                </td>
                                <td class="py-sm px-md text-sm text-on-surface">
                                    @req.OldCourse.Code &rarr; @req.NewCourse.Code
                                </td>
                                <td class="py-sm px-md">
                                    @if (req.Status == "Approved")
                                    {
                                        <span class="px-2.5 py-0.5 rounded-full bg-secondary/15 text-secondary text-xs font-semibold"><span class="lang-en">Approved</span><span class="lang-tr">Onaylandı</span></span>
                                    }
                                    else
                                    {
                                        <span class="px-2.5 py-0.5 rounded-full bg-error/15 text-error text-xs font-semibold"><span class="lang-en">Rejected</span><span class="lang-tr">Reddedildi</span></span>
                                    }
                                </td>
                                <td class="py-sm px-md text-xs text-outline font-label-sm">
                                    @req.RequestDate.ToString("dd MMM yyyy HH:mm")
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="py-md text-center text-on-surface-variant text-sm"><span class="lang-en">No previous transaction records found.</span><span class="lang-tr">Geçmiş işlem kaydı bulunmuyor.</span></div>
        }
    </div>
</div>
