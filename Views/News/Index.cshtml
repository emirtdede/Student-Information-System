@model List<Student_Information_System.Models.Announcement>
@{ ViewData["Title"] = "Duyurular ve Mesajlar"; }

@section Styles {
<style>
        .ambient-shadow {
            box-shadow: 0 10px 40px -10px rgba(0, 0, 0, 0.05);
        }
        .hide-scrollbar::-webkit-scrollbar {
            display: none;
        }
        .hide-scrollbar {
            -ms-overflow-style: none;
            scrollbar-width: none;
        }
        .message-bubble-sent {
            background: #00647e;
            color: #ffffff;
            border-bottom-right-radius: 0;
        }
        .message-bubble-received {
            background: rgba(0, 100, 126, 0.08);
            color: #0b1c30;
            border-bottom-left-radius: 0;
        }
        .dark .message-bubble-received {
            background: rgba(255, 255, 255, 0.08);
            color: #e5e5e5;
        }
</style>
}

<div class="flex-grow p-gutter relative overflow-hidden w-full">
    <div class="flex flex-col lg:flex-row h-[calc(100vh-120px)] gap-gutter">
        <!-- Left Column: Announcements -->
        <div class="w-full lg:w-1/3 flex flex-col h-full gap-base">
            <div class="flex items-center justify-between px-2 pb-2">
                <h2 class="font-h3 text-h3 text-on-background"><span class="lang-en">Announcements</span><span class="lang-tr">Duyurular</span></h2>
                <button class="text-primary hover:bg-primary/10 p-1 rounded-full transition-colors">
                    <span class="material-symbols-outlined">filter_list</span>
                </button>
            </div>
            <!-- Category Filters -->
            <div class="flex gap-2 overflow-x-auto hide-scrollbar pb-2 px-2 shrink-0">
                <button class="bg-primary text-on-primary px-4 py-1.5 rounded-full font-label-md text-label-md whitespace-nowrap shadow-sm"><span class="lang-en">All</span><span class="lang-tr">Tümü</span></button>
                <button class="bg-surface-variant text-on-surface-variant hover:bg-surface-variant/80 px-4 py-1.5 rounded-full font-label-md text-label-md whitespace-nowrap transition-colors"><span class="lang-en">Faculty</span><span class="lang-tr">Fakülte</span></button>
                <button class="bg-surface-variant text-on-surface-variant hover:bg-surface-variant/80 px-4 py-1.5 rounded-full font-label-md text-label-md whitespace-nowrap transition-colors"><span class="lang-en">Events</span><span class="lang-tr">Etkinlikler</span></button>
                <button class="bg-surface-variant text-on-surface-variant hover:bg-surface-variant/80 px-4 py-1.5 rounded-full font-label-md text-label-md whitespace-nowrap transition-colors"><span class="lang-en">System</span><span class="lang-tr">Sistem</span></button>
            </div>
            <!-- Announcements List -->
            <div class="flex-1 overflow-y-auto hide-scrollbar space-y-3 pr-2">
                @if (Model != null && Model.Count > 0)
                {
                    foreach (var announcement in Model)
                    {
                        var isNew = (DateTime.Now - announcement.DatePosted).TotalDays < 3;
                        <div class="glass-panel ambient-shadow rounded-xl p-4 cursor-pointer hover:bg-white/80 transition-all @(isNew ? "border-l-4 border-l-primary relative" : "opacity-90")">
                            @if(isNew){ <span class="absolute top-4 right-4 w-2 h-2 bg-primary rounded-full"></span> }
                            <div class="flex justify-between items-start mb-2 pr-6">
                                <span class="font-label-sm text-label-sm text-primary uppercase tracking-wider">@announcement.Category</span>
                                <span class="font-label-sm text-label-sm text-outline">@announcement.DatePosted.ToString("dd MMM yyyy")</span>
                            </div>
                            <h3 class="font-body-md text-body-md font-semibold text-on-background mb-1">@announcement.Title</h3>
                            <p class="font-label-md text-label-md text-on-surface-variant line-clamp-2">@announcement.Content</p>
                        </div>
                    }
                }
                else
                {
                    <div class="p-lg text-center font-body-lg text-on-surface-variant"><span class="lang-en">No announcements yet.</span><span class="lang-tr">Henüz duyuru bulunmamaktadır.</span></div>
                }
            </div>
        </div>
        <!-- Right Column: Direct Messaging -->
        <div class="w-full lg:w-2/3 h-[500px] lg:h-full flex flex-col glass-panel ambient-shadow rounded-[1.5rem] overflow-hidden">
            <!-- Chat Header -->
            <div class="bg-surface/80 backdrop-blur-md px-6 py-4 border-b border-outline-variant/30 flex justify-between items-center shrink-0">
                <div class="flex items-center gap-4">
                    <div class="relative">
                        <img class="w-12 h-12 rounded-full object-contain bg-white border border-outline-variant/30 shadow-sm" src="/profile.png"/>
                        <span class="absolute bottom-0 right-0 w-3 h-3 bg-secondary-fixed-dim border-2 border-surface rounded-full"></span>
                    </div>
                    <div>
                        <h3 class="font-h3 text-body-lg font-semibold text-on-background leading-tight">Prof. Dr. Ahmet Yılmaz</h3>
                        <p class="font-label-sm text-label-sm text-on-surface-variant">Academic Advisor • Computer Engineering</p>
                    </div>
                </div>
                <div class="flex gap-2">
                    <button class="p-2 text-on-surface-variant hover:bg-surface-variant/50 rounded-full transition-colors" onclick="alert('Sesli arama özelliği şu an aktif değil. / Voice call feature is not active currently.')">
                        <span class="material-symbols-outlined">call</span>
                    </button>
                </div>
            </div>
            <!-- Chat History -->
            <div class="flex-grow overflow-y-auto p-6 space-y-6 hide-scrollbar bg-surface-container-lowest/30" id="chat-history">
                <!-- Date Divider -->
                <div class="flex justify-center">
                    <span class="bg-surface-variant/50 text-on-surface-variant px-3 py-1 rounded-full font-label-sm text-label-sm backdrop-blur-sm"><span class="lang-en">Today</span><span class="lang-tr">Bugün</span></span>
                </div>
                <!-- Received Message -->
                <div class="flex gap-4 max-w-[80%]">
                    <img class="w-8 h-8 rounded-full object-contain bg-white border border-outline-variant/30 shrink-0" src="/profile.png"/>
                    <div>
                        <div class="message-bubble-received p-4 rounded-2xl font-body-md text-body-md shadow-sm">
                            <span class="lang-en">Hello, regarding your graduation project proposal, the topic looks solid. However, I'd like to see more details on the tech stack you plan to use.</span><span class="lang-tr">Merhaba, mezuniyet projesi önerinle ilgili olarak, konu sağlam görünüyor. Ancak, kullanmayı planladığın teknoloji yığını hakkında daha fazla detay görmek isterim.</span>
                        </div>
                        <span class="font-label-sm text-label-sm text-outline mt-1 block ml-1">09:15 AM</span>
                    </div>
                </div>
                <!-- Sent Message -->
                <div class="flex gap-4 max-w-[80%] ml-auto justify-end">
                    <div class="flex flex-col items-end">
                        <div class="message-bubble-sent p-4 rounded-2xl font-body-md text-body-md shadow-sm">
                            <span class="lang-en">Thank you, Professor. I was thinking of using a React frontend with a Node.js/Express backend. I'll update the document and send it over by tomorrow.</span><span class="lang-tr">Teşekkürler Hocam. React frontend ve Node.js/Express backend kullanmayı düşünüyordum. Dokümanı güncelleyip yarına kadar göndereceğim.</span>
                        </div>
                        <div class="flex items-center gap-1 mt-1 mr-1">
                            <span class="font-label-sm text-label-sm text-outline">09:30 AM</span>
                            <span class="material-symbols-outlined text-primary text-[14px]">done_all</span>
                        </div>
                    </div>
                </div>
            </div>
            <!-- Message Input Area -->
            <div class="bg-surface/80 backdrop-blur-md p-4 border-t border-outline-variant/30 shrink-0">
                <div class="flex items-end gap-3 bg-surface-container-lowest rounded-2xl p-2 border border-outline-variant/50 focus-within:ring-2 focus-within:ring-primary/50 focus-within:border-primary transition-all shadow-sm">
                    <button class="p-2 text-on-surface-variant hover:bg-surface-variant rounded-full transition-colors shrink-0" onclick="alert('Dosya ekleme özelliği şu an aktif değil. / File attachment feature is not active currently.')">
                        <span class="material-symbols-outlined">attach_file</span>
                    </button>
                    <textarea id="chat-input" class="w-full bg-transparent border-none focus:ring-0 resize-none font-body-md text-body-md p-2 max-h-32 min-h-[44px] hide-scrollbar" placeholder="Type a message..." data-tr-placeholder="Bir mesaj yazın..." data-en-placeholder="Type a message..." rows="1" onkeydown="handleKeyDown(event)"></textarea>
                    <button class="p-2 bg-primary text-on-primary hover:bg-primary-container rounded-full transition-colors shrink-0 shadow-md" onclick="sendMessage()">
                        <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1;">send</span>
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    function handleKeyDown(event) {
        if (event.key === 'Enter' && !event.shiftKey) {
            event.preventDefault();
            sendMessage();
        }
    }

    function sendMessage() {
        const input = document.getElementById("chat-input");
        const messageText = input.value.trim();
        if (!messageText) return;

        const chatHistory = document.getElementById("chat-history");
        const now = new Date();
        const timeStr = now.toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });

        // User Message HTML
        const userMsgHtml = `
            <div class="flex gap-4 max-w-[80%] ml-auto justify-end animate-fade-in">
                <div class="flex flex-col items-end">
                    <div class="message-bubble-sent p-4 rounded-2xl font-body-md text-body-md shadow-sm">
                        ${escapeHTML(messageText)}
                    </div>
                    <div class="flex items-center gap-1 mt-1 mr-1">
                        <span class="font-label-sm text-label-sm text-outline">${timeStr}</span>
                        <span class="material-symbols-outlined text-primary text-[14px]">done_all</span>
                    </div>
                </div>
            </div>
        `;

        chatHistory.insertAdjacentHTML('beforeend', userMsgHtml);
        input.value = "";
        chatHistory.scrollTop = chatHistory.scrollHeight;

        // Mock response
        setTimeout(() => {
            const botMsgHtml = `
                <div class="flex gap-4 max-w-[80%] animate-fade-in">
                    <img class="w-8 h-8 rounded-full object-contain bg-white border border-outline-variant/30 shrink-0" src="/profile.png"/>
                    <div>
                        <div class="message-bubble-received p-4 rounded-2xl font-body-md text-body-md shadow-sm">
                            <span class="lang-en">Hello Emir, I received your message. I will review the issue and provide detailed feedback as soon as possible. Have a good day.</span><span class="lang-tr">Merhaba Emir, mesajını aldım. Konuyu inceleyip en kısa sürede detaylı dönüş sağlayacağım. İyi çalışmalar dilerim.</span>
                        </div>
                        <span class="font-label-sm text-label-sm text-outline mt-1 block ml-1">${timeStr}</span>
                    </div>
                </div>
            `;
            chatHistory.insertAdjacentHTML('beforeend', botMsgHtml);
            chatHistory.scrollTop = chatHistory.scrollHeight;
        }, 1200);
    }

    function escapeHTML(str) {
        return str.replace(/[&<>'"]/g, 
            tag => ({
                '&': '&amp;',
                '<': '&lt;',
                '>': '&gt;',
                "'": '&#39;',
                '"': '&quot;'
            }[tag] || tag)
        );
    }
</script>
}
