@{ Layout = null; }
<!DOCTYPE html>

<html lang="tr">
<head>
<meta charset="utf-8"/>
<meta content="width=device-width, initial-scale=1.0" name="viewport"/>
<title data-tr="Kayıt Ol - OKÜ-OBS" data-en="Register - OKU-SIS">Kayıt Ol - OKÜ-OBS</title>
<script>
    (function() {
        var t = localStorage.getItem('theme') || (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
        if (t === 'dark') {
            document.documentElement.setAttribute('data-theme', 'dark');
            document.documentElement.classList.add('dark');
        } else {
            document.documentElement.removeAttribute('data-theme');
            document.documentElement.classList.remove('dark');
        }
    })();
</script>
<!-- Google Fonts -->
<link href="https://fonts.googleapis.com" rel="preconnect"/>
<link crossorigin="" href="https://fonts.gstatic.com" rel="preconnect"/>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet"/>
<!-- Material Symbols -->
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet"/>
<!-- Tailwind CSS -->
<script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
<script id="tailwind-config">
    tailwind.config = {
        darkMode: ['class', '[data-theme="dark"]'],
        theme: {
            extend: {
                colors: {
                    "primary": "#00647e",
                    "primary-container": "#007f9f",
                    "on-primary": "#ffffff",
                    "primary-fixed": "#baeaff",
                    "background": "#f8f9ff",
                    "on-background": "#0b1c30",
                    "surface-container-lowest": "#ffffff",
                    "on-surface": "#0b1c30",
                    "on-surface-variant": "#3e484d",
                    "outline-variant": "#bdc8ce",
                    "outline": "#6e797e",
                    "secondary": "#006c49",
                    "error": "#ba1a1a",
                    "inverse-primary": "#6cd3fa"
                },
                spacing: {
                    "xs": "4px", "sm": "12px", "md": "24px",
                    "lg": "40px", "xl": "64px", "gutter": "24px"
                },
                fontFamily: { "sans": ["Inter", "sans-serif"] }
            }
        }
    }
</script>
<style>
    *, *::before, *::after { box-sizing: border-box; }
    body { font-family: 'Inter', sans-serif; margin: 0; }
    .material-symbols-outlined { font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24; }

    /* Fluid background */
    .fluid-bg {
        background: linear-gradient(-45deg, #f8f9ff, #d3e4fe, #eff4ff, #cbdbf5);
        background-size: 400% 400%;
        animation: gradientBG 15s ease infinite;
    }
    @@keyframes gradientBG {
        0% { background-position: 0% 50%; }
        50% { background-position: 100% 50%; }
        100% { background-position: 0% 50%; }
    }
    .glass-card {
        background: rgba(255,255,255,0.72);
        backdrop-filter: blur(14px);
        -webkit-backdrop-filter: blur(14px);
        border: 1px solid rgba(255,255,255,0.5);
        box-shadow: 0 8px 32px rgba(0,0,0,0.07);
    }

    /* ======= DARK MODE ======= */
    [data-theme="dark"] body { background-color: #0f172a; color: #f1f5f9; }
    [data-theme="dark"] .fluid-bg {
        background: linear-gradient(-45deg, #0f172a, #1e293b, #0f172a, #1a2a40) !important;
    }
    [data-theme="dark"] .glass-card {
        background: rgba(15,23,42,0.85) !important;
        border: 1px solid rgba(255,255,255,0.08) !important;
    }
    [data-theme="dark"] input,
    [data-theme="dark"] select,
    [data-theme="dark"] textarea {
        background-color: #1e293b !important;
        border-color: rgba(255,255,255,0.12) !important;
        color: #f1f5f9 !important;
        background: #1e293b !important;
    }
    [data-theme="dark"] input::placeholder { color: #94a3b8 !important; }
    [data-theme="dark"] label { color: #cbd5e1 !important; }
    [data-theme="dark"] p { color: #cbd5e1 !important; }
    [data-theme="dark"] a:not(.lang-pill button) { color: #6cd3fa !important; }
    [data-theme="dark"] a:not(.lang-pill button):hover { color: #baeaff !important; }
    [data-theme="dark"] h1, [data-theme="dark"] h2, [data-theme="dark"] h3 { color: #f1f5f9 !important; }
    [data-theme="dark"] .glass-card span:not(.material-symbols-outlined) { color: #cbd5e1 !important; }
    [data-theme="dark"] .glass-card .material-symbols-outlined { color: #cbd5e1 !important; }

    /* Explicit overrides for inline styled elements inside card */
    html[data-theme="dark"] .glass-card h1 { color: #baeaff !important; }
    html[data-theme="dark"] .glass-card h2 { color: #ffffff !important; }
    html[data-theme="dark"] .glass-card p { color: #cbd5e1 !important; }
    html[data-theme="dark"] .glass-card label { color: #cbd5e1 !important; }
    html[data-theme="dark"] .glass-card span:not(button span):not(.material-symbols-outlined) { color: #cbd5e1 !important; }
    html[data-theme="dark"] .glass-card .material-symbols-outlined { color: #94a3b8 !important; }
    html[data-theme="dark"] .glass-card a { color: #6cd3fa !important; }
    html[data-theme="dark"] .glass-card a:hover { color: #baeaff !important; }

    /* ======= NAVBAR ======= */
    #obs-topbar {
        width: 100%;
        position: sticky;
        top: 0;
        z-index: 100;
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 10px 24px;
        background: rgba(255,255,255,0.35);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        border-bottom: 1px solid rgba(0,0,0,0.07);
        gap: 12px;
    }
    [data-theme="dark"] #obs-topbar {
        background: rgba(15,23,42,0.8) !important;
        border-bottom-color: rgba(255,255,255,0.08) !important;
    }
    .topbar-brand {
        display: flex;
        align-items: center;
        gap: 8px;
        text-decoration: none;
        flex-shrink: 0;
    }
    .topbar-brand img { height: 36px; width: auto; }
    .topbar-brand-name {
        font-size: 17px;
        font-weight: 700;
        color: #00647e;
        letter-spacing: -0.3px;
    }
    [data-theme="dark"] .topbar-brand-name { color: #baeaff !important; }

    .topbar-right {
        display: flex;
        align-items: center;
        gap: 8px;
        flex-wrap: nowrap;
    }

    /* Language pill */
    .lang-pill {
        display: inline-flex;
        align-items: center;
        background: rgba(255,255,255,0.55);
        border: 1px solid rgba(0,100,126,0.22);
        border-radius: 999px;
        padding: 3px;
        gap: 2px;
        flex-shrink: 0;
    }
    [data-theme="dark"] .lang-pill {
        background: rgba(30,41,59,0.95) !important;
        border-color: rgba(255,255,255,0.14) !important;
    }
    .lang-pill button {
        border: none;
        border-radius: 999px;
        padding: 4px 11px;
        font-size: 12px;
        font-weight: 700;
        cursor: pointer;
        transition: all 0.16s;
        line-height: 1.3;
        font-family: 'Inter', sans-serif;
    }
    .lang-btn-active { background: #00647e; color: #fff; }
    .lang-btn-inactive { background: transparent; color: #6e797e; }
    [data-theme="dark"] .lang-btn-active { background: #004d62; color: #baeaff; }
    [data-theme="dark"] .lang-btn-inactive { background: transparent; color: #64748b; }

    /* Theme toggle */
    #theme-btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 36px;
        height: 36px;
        border-radius: 50%;
        border: 1px solid rgba(0,100,126,0.2);
        background: rgba(255,255,255,0.55);
        color: #3e484d;
        cursor: pointer;
        transition: all 0.16s;
        flex-shrink: 0;
        font-size: 0;
    }
    #theme-btn:hover { background: rgba(0,100,126,0.12); color: #00647e; }
    [data-theme="dark"] #theme-btn {
        background: rgba(30,41,59,0.95) !important;
        color: #baeaff !important;
        border-color: rgba(255,255,255,0.14) !important;
    }
    [data-theme="dark"] #theme-btn:hover { background: rgba(186,234,255,0.1) !important; }
    #theme-btn .material-symbols-outlined { font-size: 20px; }

    /* Nav links */
    .topbar-link {
        display: inline-flex;
        align-items: center;
        gap: 4px;
        font-size: 13px;
        font-weight: 500;
        color: #3e484d;
        text-decoration: none;
        white-space: nowrap;
        transition: color 0.16s;
        padding: 4px 6px;
        border-radius: 6px;
    }
    .topbar-link .material-symbols-outlined { font-size: 18px; }
    .topbar-link:hover { color: #00647e; background: rgba(0,100,126,0.06); }
    [data-theme="dark"] .topbar-link { color: #94a3b8 !important; }
    [data-theme="dark"] .topbar-link:hover { color: #baeaff !important; background: rgba(186,234,255,0.06) !important; }

    /* Main layout */
    .page-wrap { min-height: 100vh; display: flex; flex-direction: column; }
    .main-content {
        flex: 1;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 40px 24px;
    }
    .card-wrap { width: 100%; max-width: 440px; }

    /* Footer */
    .page-footer {
        padding: 20px 24px;
        display: flex;
        flex-wrap: wrap;
        justify-content: space-between;
        align-items: center;
        gap: 12px;
        border-top: 1px solid rgba(0,0,0,0.07);
        font-size: 12px;
        color: #6e797e;
    }
    [data-theme="dark"] .page-footer {
        border-top-color: rgba(255,255,255,0.08) !important;
        color: #64748b !important;
    }
    .page-footer a { color: inherit; text-decoration: none; }
    .page-footer a:hover { color: #00647e; }
    [data-theme="dark"] .page-footer a:hover { color: #baeaff !important; }
    .footer-links { display: flex; gap: 16px; }
</style>
</head>
<body>
<div class="page-wrap fluid-bg">

<!-- ===== TOP NAVIGATION BAR ===== -->
<nav id="obs-topbar">
    <a class="topbar-brand" href="/Home/Welcome">
        <img alt="OKÜ Logo" src="/profile.png"/>
        <span class="topbar-brand-name">OKÜ-OBS</span>
    </a>
    <div class="topbar-right">
        <!-- TR / EN Language Switcher -->
        <div class="lang-pill" id="lang-pill">
            <button id="lang-tr-btn" class="lang-btn-active" onclick="changeLanguage('tr')">TR</button>
            <button id="lang-en-btn" class="lang-btn-inactive" onclick="changeLanguage('en')">EN</button>
        </div>
        <!-- Dark / Light Mode Toggle -->
        <button id="theme-btn" onclick="toggleDarkMode()" title="Temayı değiştir">
            <span id="theme-icon" class="material-symbols-outlined">dark_mode</span>
        </button>
        <!-- Nav links -->
        <a class="topbar-link" href="/Auth/Login">
            <span class="material-symbols-outlined">login</span>
            <span data-tr="Giriş Yap" data-en="Login">Giriş Yap</span>
        </a>
    </div>
</nav>

<!-- ===== MAIN CONTENT ===== -->
<div class="main-content">
<div class="card-wrap">
<div class="glass-card rounded-xl p-10 flex flex-col items-center" style="position:relative;overflow:hidden;">
    <!-- Decorative blur orb -->
    <div style="position:absolute;top:-64px;right:-64px;width:128px;height:128px;background:rgba(186,234,255,0.3);border-radius:50%;filter:blur(24px);pointer-events:none;"></div>
    <!-- Logo & Title -->
    <div style="display:flex;flex-direction:column;align-items:center;margin-bottom:24px;text-align:center;width:100%">
        <img alt="OKÜ-OBS Logo" src="/profile.png"
             style="width:96px;height:96px;object-fit:contain;border-radius:50%;padding:8px;background:rgba(0,100,126,0.06);margin-bottom:12px;"/>
        <h1 style="font-size:22px;font-weight:700;color:#00647e;margin:0 0 6px 0;letter-spacing:-0.4px;"
            data-tr="Kayıt Ol" data-en="Register">Kayıt Ol</h1>
        <p style="font-size:14px;color:#6e797e;margin:0;"
           data-tr="Öğrenci Bilgi Sistemine erişmek için hesabınızı oluşturun." data-en="Create your account to access the Student Information System.">Öğrenci Bilgi Sistemine erişmek için hesabınızı oluşturun.</p>
    </div>

    <!-- Register Form -->
    <form id="studentRegisterForm" onsubmit="handleStudentRegister(event)" style="width:100%;display:flex;flex-direction:column;gap:16px;">
        <!-- Ad Soyad -->
        <div style="display:flex;flex-direction:column;gap:6px;">
            <label for="fullName" style="font-size:13px;font-weight:600;color:#3e484d;"
                   data-tr="Ad Soyad" data-en="Full Name">Ad Soyad</label>
            <div style="position:relative;">
                <span class="material-symbols-outlined"
                      style="position:absolute;left:12px;top:50%;transform:translateY(-50%);font-size:20px;color:#6e797e;pointer-events:none;">person</span>
                <input id="fullName" name="fullName" type="text" placeholder="Adınız Soyadınız" required
                       style="width:100%;padding:10px 12px 10px 42px;border:1px solid #bdc8ce;border-radius:8px;font-size:15px;background:#fff;color:#0b1c30;outline:none;transition:border 0.2s,box-shadow 0.2s;"
                       onfocus="this.style.borderColor='#00647e';this.style.boxShadow='0 0 0 3px rgba(0,100,126,0.12)'"
                       onblur="this.style.borderColor='#bdc8ce';this.style.boxShadow='none'"/>
            </div>
        </div>
        <!-- Öğrenci Numarası -->
        <div style="display:flex;flex-direction:column;gap:6px;">
            <label for="studentId" style="font-size:13px;font-weight:600;color:#3e484d;"
                   data-tr="Öğrenci Numarası" data-en="Student Number">Öğrenci Numarası</label>
            <div style="position:relative;">
                <span class="material-symbols-outlined"
                      style="position:absolute;left:12px;top:50%;transform:translateY(-50%);font-size:20px;color:#6e797e;pointer-events:none;">badge</span>
                <input id="studentId" name="studentId" type="text" placeholder="Örn: 20240101001" required
                       style="width:100%;padding:10px 12px 10px 42px;border:1px solid #bdc8ce;border-radius:8px;font-size:15px;background:#fff;color:#0b1c30;outline:none;transition:border 0.2s,box-shadow 0.2s;"
                       onfocus="this.style.borderColor='#00647e';this.style.boxShadow='0 0 0 3px rgba(0,100,126,0.12)'"
                       onblur="this.style.borderColor='#bdc8ce';this.style.boxShadow='none'"/>
            </div>
        </div>
        <!-- Kurumsal E-posta -->
        <div style="display:flex;flex-direction:column;gap:6px;">
            <label for="email" style="font-size:13px;font-weight:600;color:#3e484d;"
                   data-tr="Kurumsal E-posta" data-en="Corporate Email">Kurumsal E-posta</label>
            <div style="position:relative;">
                <span class="material-symbols-outlined"
                      style="position:absolute;left:12px;top:50%;transform:translateY(-50%);font-size:20px;color:#6e797e;pointer-events:none;">mail</span>
                <input id="email" name="email" type="email" placeholder="ogrenci@@ogr.oku.edu.tr" required
                       style="width:100%;padding:10px 12px 10px 42px;border:1px solid #bdc8ce;border-radius:8px;font-size:15px;background:#fff;color:#0b1c30;outline:none;transition:border 0.2s,box-shadow 0.2s;"
                       onfocus="this.style.borderColor='#00647e';this.style.boxShadow='0 0 0 3px rgba(0,100,126,0.12)'"
                       onblur="this.style.borderColor='#bdc8ce';this.style.boxShadow='none'"/>
            </div>
            <p style="font-size:12px;color:#6e797e;margin:4px 0 0 0;"
               data-tr="Sadece @@ogr.oku.edu.tr uzantılı e-postalar kabul edilir." data-en="Only @@ogr.oku.edu.tr emails are accepted.">Sadece @@ogr.oku.edu.tr uzantılı e-postalar kabul edilir.</p>
        </div>
        <!-- Şifre -->
        <div style="display:flex;flex-direction:column;gap:6px;">
            <label for="password" style="font-size:13px;font-weight:600;color:#3e484d;"
                   data-tr="Şifre" data-en="Password">Şifre</label>
            <div style="position:relative;">
                <span class="material-symbols-outlined"
                      style="position:absolute;left:12px;top:50%;transform:translateY(-50%);font-size:20px;color:#6e797e;pointer-events:none;">lock</span>
                <input id="password" name="password" type="password" placeholder="••••••••" required
                       style="width:100%;padding:10px 42px 10px 42px;border:1px solid #bdc8ce;border-radius:8px;font-size:15px;background:#fff;color:#0b1c30;outline:none;transition:border 0.2s,box-shadow 0.2s;"
                       onfocus="this.style.borderColor='#00647e';this.style.boxShadow='0 0 0 3px rgba(0,100,126,0.12)'"
                       onblur="this.style.borderColor='#bdc8ce';this.style.boxShadow='none'"/>
                <button type="button" onclick="togglePasswordVisibility()" aria-label="Şifreyi Göster"
                        style="position:absolute;right:10px;top:50%;transform:translateY(-50%);background:none;border:none;cursor:pointer;color:#6e797e;display:flex;align-items:center;">
                    <span id="visibilityIcon" class="material-symbols-outlined" style="font-size:20px;">visibility</span>
                </button>
            </div>
        </div>
        <!-- Şifreyi Onayla -->
        <div style="display:flex;flex-direction:column;gap:6px;">
            <label for="confirmPassword" style="font-size:13px;font-weight:600;color:#3e484d;"
                   data-tr="Şifreyi Onayla" data-en="Confirm Password">Şifreyi Onayla</label>
            <div style="position:relative;">
                <span class="material-symbols-outlined"
                      style="position:absolute;left:12px;top:50%;transform:translateY(-50%);font-size:20px;color:#6e797e;pointer-events:none;">lock_reset</span>
                <input id="confirmPassword" name="confirmPassword" type="password" placeholder="••••••••" required
                       style="width:100%;padding:10px 12px 10px 42px;border:1px solid #bdc8ce;border-radius:8px;font-size:15px;background:#fff;color:#0b1c30;outline:none;transition:border 0.2s,box-shadow 0.2s;"
                       onfocus="this.style.borderColor='#00647e';this.style.boxShadow='0 0 0 3px rgba(0,100,126,0.12)'"
                       onblur="this.style.borderColor='#bdc8ce';this.style.boxShadow='none'"/>
            </div>
        </div>
        <!-- Submit -->
        <button type="submit"
                style="width:100%;padding:12px;background:#00647e;color:#fff;border:none;border-radius:8px;font-size:15px;font-weight:600;cursor:pointer;display:flex;align-items:center;justify-content:center;gap:8px;transition:background 0.2s,transform 0.1s;font-family:'Inter',sans-serif;"
                onmouseover="this.style.background='#004d62'" onmouseout="this.style.background='#00647e'"
                onmousedown="this.style.transform='scale(0.98)'" onmouseup="this.style.transform='scale(1)'">
            <span data-tr="Kayıt Ol" data-en="Register">Kayıt Ol</span>
            <span class="material-symbols-outlined" style="font-size:20px;">how_to_reg</span>
        </button>
    </form>

    <!-- Login link -->
    <div style="margin-top:24px;padding-top:20px;border-top:1px solid rgba(0,0,0,0.08);text-align:center;width:100%;">
        <span style="font-size:14px;color:#6e797e;"
              data-tr="Zaten bir hesabın var mı? " data-en="Already have an account? ">Zaten bir hesabın var mı? </span>
        <a href="/Auth/Login" style="font-size:14px;font-weight:700;color:#00647e;text-decoration:none;"
           data-tr="Giriş Yap" data-en="Login">Giriş Yap</a>
    </div>
</div>
</div>
</div>

<!-- ===== FOOTER ===== -->
<footer class="page-footer">
    <span data-tr="© @DateTime.Now.Year Osmaniye Korkut Ata Üniversitesi. Tüm hakları saklıdır. Geliştirici: Emir Tarık Dede." data-en="© @DateTime.Now.Year Osmaniye Korkut Ata University. All rights reserved. Developer: Emir Tarık Dede.">© @DateTime.Now.Year Osmaniye Korkut Ata Üniversitesi. Tüm hakları saklıdır. Geliştirici: Emir Tarık Dede.</span>
    <div class="footer-links">
        <a href="/Support/PrivacyPolicy" data-tr="Gizlilik Politikası" data-en="Privacy Policy">Gizlilik Politikası</a>
        <a href="/Support/TermsOfUse" data-tr="Kullanım Şartları" data-en="Terms of Use">Kullanım Şartları</a>
        <a href="/Support/HelpCenter" data-tr="Destek" data-en="Support">Destek</a>
    </div>
</footer>

</div><!-- .page-wrap -->
<script>
    function togglePasswordVisibility() {
        const passwordInput = document.getElementById('password');
        const icon = document.getElementById('visibilityIcon');
        if (passwordInput.type === 'password') {
            passwordInput.type = 'text';
            icon.textContent = 'visibility_off';
        } else {
            passwordInput.type = 'password';
            icon.textContent = 'visibility';
        }
    }

    function handleStudentRegister(e) {
        e.preventDefault();
        const fullName = document.getElementById('fullName').value.trim();
        const studentId = document.getElementById('studentId').value.trim();
        const email = document.getElementById('email').value.trim();
        const password = document.getElementById('password').value;
        const confirmPassword = document.getElementById('confirmPassword').value;

        if (!fullName || !studentId || !email || !password || !confirmPassword) {
            alert('Lütfen tüm alanları doldurunuz.');
            return;
        }

        if (!email.endsWith('@@ogr.oku.edu.tr')) {
            alert('Lütfen kurumsal e-posta adresinizi giriniz (@@ogr.oku.edu.tr ile bitmelidir).');
            return;
        }

        if (password !== confirmPassword) {
            alert('Şifreler eşleşmiyor.');
            return;
        }

        if (password.length < 8) {
            alert('Şifreniz en az 8 karakter uzunluğunda olmalıdır.');
            return;
        }

        fetch('/Auth/Register', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/x-www-form-urlencoded',
            },
            body: new URLSearchParams({
                fullName: fullName,
                studentId: studentId,
                email: email,
                password: password
            })
        })
        .then(response => response.json())
        .then(data => {
            if (data.success) {
                alert('Kayıt başarılı! Giriş sayfasına yönlendiriliyorsunuz.');
                window.location.href = '/Auth/Login';
            } else {
                alert(data.message || 'Kayıt sırasında bir hata oluştu.');
            }
        })
        .catch(error => {
            console.error('Error:', error);
            alert('Sunucuyla iletişim kurulurken bir hata oluştu.');
        });
    }

    // ===== THEME =====
    function toggleDarkMode() {
        var isDark = document.documentElement.getAttribute('data-theme') === 'dark';
        if (isDark) {
            document.documentElement.removeAttribute('data-theme');
            document.documentElement.classList.remove('dark');
            localStorage.setItem('theme', 'light');
        } else {
            document.documentElement.setAttribute('data-theme', 'dark');
            document.documentElement.classList.add('dark');
            localStorage.setItem('theme', 'dark');
        }
        updateThemeIcon();
    }
    function updateThemeIcon() {
        var icon = document.getElementById('theme-icon');
        if (!icon) return;
        var isDark = document.documentElement.getAttribute('data-theme') === 'dark';
        icon.textContent = isDark ? 'light_mode' : 'dark_mode';
    }

    // ===== LANGUAGE =====
    function changeLanguage(lang) {
        localStorage.setItem('lang', lang);
        document.querySelectorAll('[data-tr]').forEach(function(el) {
            el.textContent = lang === 'en' ? el.getAttribute('data-en') : el.getAttribute('data-tr');
        });
        // Update button styles
        var trBtn = document.getElementById('lang-tr-btn');
        var enBtn = document.getElementById('lang-en-btn');
        if (trBtn && enBtn) {
            if (lang === 'en') {
                trBtn.className = 'lang-btn-inactive';
                enBtn.className = 'lang-btn-active';
            } else {
                trBtn.className = 'lang-btn-active';
                enBtn.className = 'lang-btn-inactive';
            }
        }
    }

    // ===== INIT =====
    document.addEventListener('DOMContentLoaded', function() {
        updateThemeIcon();
        changeLanguage(localStorage.getItem('lang') || 'tr');
    });
</script>
</body>
</html>