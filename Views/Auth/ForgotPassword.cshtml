    <script>
        // Password Visibility Toggle
        function togglePasswordVisibility() {
            const pwdInput = document.getElementById('new-password');
            const icon = event.currentTarget.querySelector('span');
            if (pwdInput.type === 'password') {
                pwdInput.type = 'text';
                icon.textContent = 'visibility';
            } else {
                pwdInput.type = 'password';
                icon.textContent = 'visibility_off';
            }
        }

        // Auto-tabbing and limit to numbers for 6-digit code
        const digitInputs = document.querySelectorAll('#step-2-content input[type="text"]');
        digitInputs.forEach((input, index) => {
            input.addEventListener('input', (e) => {
                // Ensure only numbers
                input.value = input.value.replace(/[^0-9]/g, '');
                if (input.value && index < digitInputs.length - 1) {
                    digitInputs[index + 1].focus();
                }
            });
            input.addEventListener('keydown', (e) => {
                if (e.key === 'Backspace' && !input.value && index > 0) {
                    digitInputs[index - 1].focus();
                }
            });
        });

        function goToStep(step) {
            // Validation before proceeding
            if (step === 2) {
                const identifier = document.getElementById('identifier').value.trim();
                if (!identifier) {
                    alert('Lütfen Öğrenci Numaranızı veya E-posta adresinizi giriniz.');
                    return;
                }
            }
            if (step === 3) {
                let code = '';
                digitInputs.forEach(input => code += input.value);
                if (code.length < 6) {
                    alert('Lütfen 6 haneli güvenlik kodunun tamamını giriniz.');
                    return;
                }
            }

            const steps = [1, 2, 3];
            
            steps.forEach(s => {
                const content = document.getElementById(`step-${s}-content`);
                const dot = document.getElementById(`step-${s}-dot`);
                
                if (s === step) {
                    // Show target step
                    content.classList.remove('hidden');
                    // Small delay to allow display block to apply before animating opacity
                    setTimeout(() => {
                        content.classList.remove('opacity-0', 'translate-x-8', 'absolute', 'top-8', 'left-8', 'right-8');
                        content.classList.add('opacity-100', 'translate-x-0', 'relative');
                    }, 50);
                    
                    dot.classList.replace('bg-surface-variant', 'bg-primary');
                    dot.classList.replace('text-on-surface-variant', 'text-on-primary');
                } else if (s < step) {
                    // Hide previous steps (animate out left)
                    content.classList.remove('opacity-100', 'translate-x-0', 'relative');
                    content.classList.add('opacity-0', '-translate-x-8', 'absolute', 'top-8', 'left-8', 'right-8');
                    setTimeout(() => {
                        if(s !== step) content.classList.add('hidden');
                    }, 300);

                    // Keep previous dots active styling
                    dot.classList.replace('bg-surface-variant', 'bg-primary');
                    dot.classList.replace('text-on-surface-variant', 'text-on-primary');
                } else {
                    // Reset upcoming steps
                    content.classList.remove('opacity-100', 'translate-x-0', '-translate-x-8', 'relative');
                    content.classList.add('opacity-0', 'translate-x-8', 'absolute', 'top-8', 'left-8', 'right-8', 'hidden');
                    
                    dot.classList.replace('bg-primary', 'bg-surface-variant');
                    dot.classList.replace('text-on-primary', 'text-on-surface-variant');
                }
            });

            // Update Progress Bar
            const progressBar = document.getElementById('progress-bar');
            if(step === 1) progressBar.style.width = '0%';
            if(step === 2) progressBar.style.width = '50%';
            if(step === 3) progressBar.style.width = '100%';
        }

        function submitNewPassword() {
            const newPassword = document.getElementById('new-password').value;
            const confirmPassword = document.getElementById('confirm-password').value;

            if (newPassword.length < 8) {
                alert('Şifreniz en az 8 karakter olmalıdır.');
                return;
            }
            if (newPassword !== confirmPassword) {
                alert('Girdiğiniz şifreler eşleşmiyor.');
                return;
            }

            alert('Şifreniz başarıyla güncellendi! Giriş sayfasına yönlendiriliyorsunuz.');
            window.location.href = '/Auth/Login';
        }
        function toggleDarkMode() {
            var isDark = document.documentElement.getAttribute('data-theme') === 'dark';
            if (isDark) {
                document.documentElement.removeAttribute('data-theme');
                document.documentElement.classList.remove('dark');
                localStorage.setItem('theme','light');
            } else {
                document.documentElement.setAttribute('data-theme','dark');
                document.documentElement.classList.add('dark');
                localStorage.setItem('theme','dark');
            }
            updateThemeIcon();
        }
        function updateThemeIcon() {
            var icon = document.getElementById('theme-icon');
            if (!icon) return;
            icon.textContent = document.documentElement.getAttribute('data-theme') === 'dark' ? 'light_mode' : 'dark_mode';
        }
        function changeLanguage(lang) {
            localStorage.setItem('lang', lang);
            document.querySelectorAll('[data-tr]').forEach(function(el) {
                el.textContent = lang === 'en' ? el.getAttribute('data-en') : el.getAttribute('data-tr');
            });
            document.querySelectorAll('[data-tr-placeholder]').forEach(function(el) {
                el.placeholder = lang === 'en' ? el.getAttribute('data-en-placeholder') : el.getAttribute('data-tr-placeholder');
            });
            var trBtn = document.getElementById('lang-tr-btn');
            var enBtn = document.getElementById('lang-en-btn');
            if (trBtn && enBtn) {
                if (lang === 'en') { trBtn.className = 'lang-btn-inactive'; enBtn.className = 'lang-btn-active'; }
                else { trBtn.className = 'lang-btn-active'; enBtn.className = 'lang-btn-inactive'; }
            }
        }
        document.addEventListener('DOMContentLoaded', function() {
            updateThemeIcon();
            changeLanguage(localStorage.getItem('lang') || 'tr');
        });
    </script>
</body></html>